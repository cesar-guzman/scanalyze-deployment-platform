{
  "service_name": "ingest-api",
  "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/scanalyze/ingest-api:latest",
  "cpu": 512,
  "memory": 1024,
  "essential": true,
  "port_mappings": [{"containerPort": 8080, "protocol": "tcp"}],
  "environment": [
    {"name": "SCANALYZE_DEPLOYMENT_CUSTOMER_ID", "value": "cust_example"}
