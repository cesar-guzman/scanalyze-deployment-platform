{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/saved-plan.v1.schema.json",
  "title": "Scanalyze Exact Saved Plan v1",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "customer_id",
    "deployment_id",
    "account_id",
    "region",
    "environment",
    "execution_id",
    "change_id",
    "layer",
    "release_version",
    "release_digest",
    "release_policy_digest",
    "release_projection_digest",
    "plan_policy_digest",
    "github_environment",
    "github_deployment_identity_digest",
    "environment_configuration_digest",
    "platform_authority_digest",
    "registry_record_digest",
    "account_ready_digest",
    "execution_lock_digest",
    "backend_binding_digest",
    "contract_resolution_digest",
    "toolchain_digest",
    "root_module_digest",
    "source_revision_digest",
    "state_lineage",
    "state_serial",
    "plan_sha256",
    "plan_size_bytes",
    "storage",
    "created_at",
    "expires_at",
    "record_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "record_type": { "const": "saved_plan" },
    "customer_id": { "$ref": "#/$defs/customer_id" },
    "deployment_id": { "$ref": "#/$defs/deployment_id" },
    "account_id": { "$ref": "#/$defs/account_id" },
    "region": { "$ref": "#/$defs/region" },
    "environment": { "enum": ["sandbox", "dev", "staging"] },
    "execution_id": { "type": "string", "pattern": "^exec_[0-9A-HJKMNP-TV-Z]{26}$" },
    "change_id": { "type": "string", "pattern": "^chg_[0-9A-HJKMNP-TV-Z]{26}$" },
    "layer": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "release_version": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "release_digest": { "$ref": "#/$defs/digest" },
    "release_policy_digest": { "$ref": "#/$defs/digest" },
    "release_projection_digest": { "$ref": "#/$defs/digest" },
    "plan_policy_digest": { "$ref": "#/$defs/digest" },
    "github_environment": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "github_deployment_identity_digest": { "$ref": "#/$defs/digest" },
    "environment_configuration_digest": { "$ref": "#/$defs/digest" },
    "platform_authority_digest": { "$ref": "#/$defs/digest" },
    "registry_record_digest": { "$ref": "#/$defs/digest" },
    "account_ready_digest": { "$ref": "#/$defs/digest" },
    "execution_lock_digest": { "$ref": "#/$defs/digest" },
    "backend_binding_digest": { "$ref": "#/$defs/digest" },
    "contract_resolution_digest": { "$ref": "#/$defs/digest" },
    "toolchain_digest": { "$ref": "#/$defs/digest" },
    "root_module_digest": { "$ref": "#/$defs/digest" },
    "source_revision_digest": { "$ref": "#/$defs/digest" },
    "state_lineage": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$" },
    "state_serial": { "type": "integer", "minimum": 0 },
    "plan_sha256": { "$ref": "#/$defs/digest" },
    "plan_size_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
    "storage": {
      "type": "object",
      "required": ["bucket", "object_key", "object_version_id"],
      "additionalProperties": false,
      "properties": {
        "bucket": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$" },
        "object_key": {
          "type": "string",
          "pattern": "^plan-execution/dep_[0-9A-HJKMNP-TV-Z]{26}/chg_[0-9A-HJKMNP-TV-Z]{26}/[a-z][a-z0-9-]{1,63}/plan\\.tfplan$"
        },
        "object_version_id": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "record_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "customer_id": { "type": "string", "pattern": "^cust_[0-9A-HJKMNP-TV-Z]{26}$" },
    "deployment_id": { "type": "string", "pattern": "^dep_[0-9A-HJKMNP-TV-Z]{26}$" },
    "account_id": { "type": "string", "pattern": "^(?!000000000000$)[0-9]{12}$" },
    "region": { "type": "string", "pattern": "^[a-z]{2}(?:-[a-z]+)+-[0-9]+$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
