{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-phase-b-identity-materialization-receipt.v1.schema.json",
  "title": "GUG-221 Phase B provider-derived identity materialization receipt",
  "description": "Input-only shape contract. Schema conformance and a self-digest do not establish live provider materialization or execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "work_package",
    "phase",
    "source_commit",
    "authority_account_id",
    "management_account_id",
    "region",
    "identity_center_application_arn",
    "identity_center_instance_arn",
    "identity_store_arn",
    "identity_center_redirect_uri",
    "operator_identity_store_user_id",
    "invoker_principal_arn",
    "broker_code_signing_config_arn",
    "broker_topology_signing_key_arn",
    "oauth_state_digest",
    "provider_state_sha256",
    "checks",
    "verifiers",
    "evaluated_at",
    "evidence_status",
    "authority_status",
    "production_status",
    "receipt_sha256"
  ],
  "properties": {
    "artifact_type": {
      "const": "scanalyze.platform_authority.lambda_audit_repair_phase_b_identity_materialization_receipt.v1"
    },
    "schema_version": { "const": 1 },
    "work_package": { "const": "GUG-221" },
    "phase": { "const": "PRE_B_IDENTITY_MATERIALIZATION" },
    "source_commit": { "$ref": "#/$defs/commit" },
    "authority_account_id": { "const": "042360977644" },
    "management_account_id": { "const": "839393571433" },
    "region": { "const": "us-east-1" },
    "identity_center_application_arn": {
      "type": "string",
      "pattern": "^arn:aws:sso::839393571433:application/ssoins-[A-Za-z0-9]{16}/apl-[A-Za-z0-9]{16}$"
    },
    "identity_center_instance_arn": {
      "type": "string",
      "pattern": "^arn:aws:sso:::instance/ssoins-[A-Za-z0-9]{16}$"
    },
    "identity_store_arn": {
      "type": "string",
      "pattern": "^arn:aws:identitystore::839393571433:identitystore/d-[0-9a-f]{10}$"
    },
    "identity_center_redirect_uri": {
      "type": "string",
      "pattern": "^http://127[.]0[.]0[.]1:[1-9][0-9]{3,4}/callback$"
    },
    "operator_identity_store_user_id": { "$ref": "#/$defs/principal_id" },
    "invoker_principal_arn": {
      "type": "string",
      "pattern": "^arn:aws:iam::042360977644:role/aws-reserved/sso[.]amazonaws[.]com/us-east-1/AWSReservedSSO_ScanalyzeGug221PhaseBInvoker_[0-9a-f]{16}$"
    },
    "broker_code_signing_config_arn": {
      "type": "string",
      "pattern": "^arn:aws:lambda:us-east-1:042360977644:code-signing-config:csc-[A-Za-z0-9]{17}$"
    },
    "broker_topology_signing_key_arn": {
      "type": "string",
      "pattern": "^arn:aws:kms:us-east-1:042360977644:key/[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "oauth_state_digest": { "$ref": "#/$defs/prefixed_digest" },
    "provider_state_sha256": { "$ref": "#/$defs/raw_digest" },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "application_verified",
        "single_operator_assignment_verified",
        "invoker_role_verified",
        "code_signing_config_verified",
        "topology_signing_key_verified",
        "pending_operations_absent",
        "alternate_assignments_absent"
      ],
      "properties": {
        "application_verified": { "const": true },
        "single_operator_assignment_verified": { "const": true },
        "invoker_role_verified": { "const": true },
        "code_signing_config_verified": { "const": true },
        "topology_signing_key_verified": { "const": true },
        "pending_operations_absent": { "const": true },
        "alternate_assignments_absent": { "const": true }
      }
    },
    "verifiers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["management", "authority"],
      "properties": {
        "management": { "$ref": "#/$defs/management_verifier" },
        "authority": { "$ref": "#/$defs/authority_verifier" }
      }
    },
    "evaluated_at": { "$ref": "#/$defs/timestamp" },
    "evidence_status": {
      "const": "PHASE_B_IDENTITY_MATERIALIZATION_PROVIDER_VERIFIED"
    },
    "authority_status": {
      "const": "PROVIDER_DERIVED_NOT_EXECUTION_AUTHORITY"
    },
    "production_status": { "const": "NO-GO" },
    "receipt_sha256": { "$ref": "#/$defs/raw_digest" }
  },
  "$defs": {
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "raw_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "prefixed_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "principal_id": {
      "type": "string",
      "pattern": "^(?:[0-9a-f]{10}-)?[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "management_verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "account_id", "caller_arn"],
      "properties": {
        "profile": { "const": "839393571433_ReadOnlyAccess" },
        "account_id": { "const": "839393571433" },
        "caller_arn": {
          "type": "string",
          "pattern": "^arn:aws:sts::839393571433:assumed-role/AWSReservedSSO_AWSReadOnlyAccess_[0-9a-f]{16}/[A-Za-z0-9+=,.@_-]{1,64}$"
        }
      }
    },
    "authority_verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "account_id", "caller_arn"],
      "properties": {
        "profile": { "const": "042360977644_ReadOnlyAccess" },
        "account_id": { "const": "042360977644" },
        "caller_arn": {
          "type": "string",
          "pattern": "^arn:aws:sts::042360977644:assumed-role/AWSReservedSSO_AWSReadOnlyAccess_[0-9a-f]{16}/[A-Za-z0-9+=,.@_-]{1,64}$"
        }
      }
    }
  }
}
