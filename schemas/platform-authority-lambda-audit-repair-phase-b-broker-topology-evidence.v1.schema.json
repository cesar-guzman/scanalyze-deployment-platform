{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-phase-b-broker-topology-evidence.v1.schema.json",
  "title": "GUG-221 Phase B Broker Provider Topology Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "environment",
    "production",
    "status",
    "authority_account_id",
    "management_account_id",
    "region",
    "provider_readback",
    "identity_center_application_verified",
    "single_operator_assignment_verified",
    "broker_alias_verified",
    "broker_role_verified",
    "proof_role_verified",
    "ledger_resource_policy_verified",
    "direct_qualified_invoke_only",
    "function_url_absent",
    "synchronous_client_context_required",
    "asynchronous_effect_blocked",
    "pending_operations_absent",
    "invoker_policy_sha256",
    "broker_policy_sha256",
    "proof_policy_sha256",
    "application_actor_policy_sha256",
    "broker_topology_sha256",
    "topology_state_digest",
    "collected_at",
    "signing_key_arn",
    "signature_algorithm",
    "signature",
    "receipt_digest"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "record_type": {"const": "platform_authority_lambda_audit_repair_phase_b_broker_topology_evidence"},
    "environment": {"const": "non-production"},
    "production": {"const": false},
    "status": {"const": "PROVIDER_TOPOLOGY_READBACK_VERIFIED"},
    "authority_account_id": {"const": "042360977644"},
    "management_account_id": {"const": "839393571433"},
    "region": {"const": "us-east-1"},
    "provider_readback": {"const": true},
    "identity_center_application_verified": {"const": true},
    "single_operator_assignment_verified": {"const": true},
    "broker_alias_verified": {"const": true},
    "broker_role_verified": {"const": true},
    "proof_role_verified": {"const": true},
    "ledger_resource_policy_verified": {"const": true},
    "direct_qualified_invoke_only": {"const": true},
    "function_url_absent": {"const": true},
    "synchronous_client_context_required": {"const": true},
    "asynchronous_effect_blocked": {"const": true},
    "pending_operations_absent": {"const": true},
    "invoker_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "broker_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "proof_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "application_actor_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "broker_topology_sha256": {"$ref": "#/$defs/digest"},
    "topology_state_digest": {"$ref": "#/$defs/digest"},
    "collected_at": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "signing_key_arn": {
      "type": "string",
      "pattern": "^arn:aws:kms:us-east-1:042360977644:key/[0-9a-fA-F-]{36}$"
    },
    "signature_algorithm": {"const": "ECDSA_SHA_256"},
    "signature": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]+={0,2}$",
      "minLength": 80,
      "maxLength": 1024
    },
    "receipt_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "raw_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
