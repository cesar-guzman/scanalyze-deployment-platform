{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/live-health-receipt.v1.schema.json",
  "title": "Scanalyze Non-Production Health Gate Receipt v1",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "customer_id",
    "deployment_id",
    "account_id",
    "region",
    "environment",
    "execution_id",
    "change_id",
    "layer",
    "plan_record_digest",
    "source_ledger_digest",
    "source_ledger_version",
    "release_digest",
    "contract_resolution_digest",
    "state_lineage",
    "state_serial",
    "checked_at",
    "status",
    "checks",
    "receipt_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "record_type": { "const": "live_health_receipt" },
    "customer_id": { "type": "string", "pattern": "^cust_[0-9A-HJKMNP-TV-Z]{26}$" },
    "deployment_id": { "type": "string", "pattern": "^dep_[0-9A-HJKMNP-TV-Z]{26}$" },
    "account_id": { "type": "string", "pattern": "^(?!000000000000$)[0-9]{12}$" },
    "region": { "type": "string", "pattern": "^[a-z]{2}(?:-[a-z]+)+-[0-9]+$" },
    "environment": { "enum": ["sandbox", "dev", "staging"] },
    "execution_id": { "type": "string", "pattern": "^exec_[0-9A-HJKMNP-TV-Z]{26}$" },
    "change_id": { "type": "string", "pattern": "^chg_[0-9A-HJKMNP-TV-Z]{26}$" },
    "layer": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "plan_record_digest": { "$ref": "#/$defs/digest" },
    "source_ledger_digest": { "$ref": "#/$defs/digest" },
    "source_ledger_version": { "type": "integer", "minimum": 1 },
    "release_digest": { "$ref": "#/$defs/digest" },
    "contract_resolution_digest": { "$ref": "#/$defs/digest" },
    "state_lineage": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$" },
    "state_serial": { "type": "integer", "minimum": 0 },
    "checked_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["PASSED", "FAILED"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "required": ["name", "passed", "code"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$" },
          "passed": { "type": "boolean" },
          "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$" }
        }
      }
    },
    "receipt_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
