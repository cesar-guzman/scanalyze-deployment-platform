{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-pep-parameters.v1.schema.json",
  "title": "GUG-221 Phase B PEP parameter handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type", "schema_version", "work_package", "source_commit",
    "stack_name", "change_set_name", "signed_artifact_receipt_sha256",
    "deployment_contract_sha256", "gug220_intent_sha256",
    "gug220_ledger_sha256", "gug220_receipt_sha256",
    "gug220_evidence_sha256", "delegation_live_receipt_sha256",
    "template_sha256", "stack_tags", "parameters", "authority_status",
    "production_status"
  ],
  "properties": {
    "artifact_type": { "const": "scanalyze.platform_authority.lambda_audit_repair_pep_parameters.v1" },
    "schema_version": { "const": 1 },
    "work_package": { "const": "GUG-221" },
    "source_commit": { "$ref": "#/$defs/commit" },
    "stack_name": { "const": "scanalyze-platform-authority-lambda-audit-repair-pep" },
    "change_set_name": { "const": "gug221-lambda-audit-repair-pep-create" },
    "signed_artifact_receipt_sha256": { "$ref": "#/$defs/digest" },
    "deployment_contract_sha256": { "$ref": "#/$defs/digest" },
    "gug220_intent_sha256": { "$ref": "#/$defs/digest" },
    "gug220_ledger_sha256": { "$ref": "#/$defs/digest" },
    "gug220_receipt_sha256": { "$ref": "#/$defs/digest" },
    "gug220_evidence_sha256": { "$ref": "#/$defs/digest" },
    "delegation_live_receipt_sha256": { "$ref": "#/$defs/digest" },
    "template_sha256": { "$ref": "#/$defs/digest" },
    "stack_tags": { "$ref": "#/$defs/stack_tags" },
    "parameters": {
      "type": "array",
      "minItems": 29,
      "maxItems": 29,
      "prefixItems": [
        { "$ref": "#/$defs/p_authority" },
        { "$ref": "#/$defs/p_management" },
        { "$ref": "#/$defs/p_source" },
        { "$ref": "#/$defs/p_repair_id" },
        { "$ref": "#/$defs/p_principal" },
        { "$ref": "#/$defs/p_store" },
        { "$ref": "#/$defs/p_instance" },
        { "$ref": "#/$defs/p_collector_ps" },
        { "$ref": "#/$defs/p_invoker_ps" },
        { "$ref": "#/$defs/p_collector_digest" },
        { "$ref": "#/$defs/p_invoker_digest" },
        { "$ref": "#/$defs/p_ledger_digest" },
        { "$ref": "#/$defs/p_tags" },
        { "$ref": "#/$defs/p_not_before" },
        { "$ref": "#/$defs/p_not_after" },
        { "$ref": "#/$defs/p_saml" },
        { "$ref": "#/$defs/p_kms_mode" },
        { "$ref": "#/$defs/p_kms_key" },
        { "$ref": "#/$defs/p_boto3" },
        { "$ref": "#/$defs/p_botocore" },
        { "$ref": "#/$defs/p_repair_bucket" },
        { "$ref": "#/$defs/p_repair_key" },
        { "$ref": "#/$defs/p_repair_version" },
        { "$ref": "#/$defs/p_repair_sha" },
        { "$ref": "#/$defs/p_reconcile_bucket" },
        { "$ref": "#/$defs/p_reconcile_key" },
        { "$ref": "#/$defs/p_reconcile_version" },
        { "$ref": "#/$defs/p_reconcile_sha" },
        { "$ref": "#/$defs/p_signing_profile" }
      ],
      "items": false
    },
    "authority_status": { "const": "NON_AUTHORITATIVE_DERIVATION_ONLY" },
    "production_status": { "const": "NO-GO" }
  },
  "$defs": {
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "lambda_digest": { "type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "permission_set_arn": { "type": "string", "pattern": "^arn:aws:sso:::permissionSet/ssoins-[A-Za-z0-9]{16}/ps-[A-Za-z0-9]{16}$" },
    "parameter": {
      "type": "object", "additionalProperties": false,
      "required": ["ParameterKey", "ParameterValue"],
      "properties": {
        "ParameterKey": { "type": "string" },
        "ParameterValue": { "type": "string", "not": { "const": "****" } }
      }
    },
    "stack_tags": {
      "type": "object", "additionalProperties": false,
      "required": ["environment", "managed_by", "production", "service", "source_commit", "work_package"],
      "properties": {
        "environment": { "const": "non-production" }, "managed_by": { "const": "cloudformation" },
        "production": { "const": "false" }, "service": { "const": "scanalyze-platform-authority" },
        "source_commit": { "$ref": "#/$defs/commit" }, "work_package": { "const": "GUG-221" }
      }
    },
    "p_authority": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "AuthorityAccountId" }, "ParameterValue": { "const": "042360977644" } } }] },
    "p_management": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "ManagementAccountId" }, "ParameterValue": { "const": "839393571433" } } }] },
    "p_source": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "SourceCommit" }, "ParameterValue": { "$ref": "#/$defs/commit" } } }] },
    "p_repair_id": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairId" }, "ParameterValue": { "type": "string", "pattern": "^gug221-[0-9a-f]{64}$" } } }] },
    "p_principal": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "PrincipalId" }, "ParameterValue": { "type": "string", "pattern": "^(?:[0-9a-f]{10}-)?[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$" } } }] },
    "p_store": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "IdentityStoreId" }, "ParameterValue": { "type": "string", "pattern": "^d-[0-9a-f]{10}$" } } }] },
    "p_instance": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "IdentityCenterInstanceArn" }, "ParameterValue": { "type": "string", "pattern": "^arn:aws:sso:::instance/ssoins-[A-Za-z0-9]{16}$" } } }] },
    "p_collector_ps": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "CollectorPermissionSetArn" }, "ParameterValue": { "$ref": "#/$defs/permission_set_arn" } } }] },
    "p_invoker_ps": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairInvokerPermissionSetArn" }, "ParameterValue": { "$ref": "#/$defs/permission_set_arn" } } }] },
    "p_collector_digest": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "CollectorPolicyDigest" }, "ParameterValue": { "$ref": "#/$defs/digest" } } }] },
    "p_invoker_digest": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairInvokerPolicyDigest" }, "ParameterValue": { "$ref": "#/$defs/digest" } } }] },
    "p_ledger_digest": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "OriginalGug220LedgerDigest" }, "ParameterValue": { "$ref": "#/$defs/digest" } } }] },
    "p_tags": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "ExpectedPermissionSetTagsJson" }, "ParameterValue": { "type": "string", "minLength": 2, "maxLength": 2048, "pattern": "^\\{.*\\}$" } } }] },
    "p_not_before": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairNotBefore" }, "ParameterValue": { "$ref": "#/$defs/timestamp" } } }] },
    "p_not_after": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairNotAfter" }, "ParameterValue": { "$ref": "#/$defs/timestamp" } } }] },
    "p_saml": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "CollectorSamlProviderArn" }, "ParameterValue": { "type": "string", "pattern": "^arn:aws:iam::042360977644:saml-provider/AWSSSO_[A-Za-z0-9+=,.@_-]+_DO_NOT_DELETE$" } } }] },
    "p_kms_mode": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "IdentityCenterKmsMode" }, "ParameterValue": { "enum": ["AWS_OWNED_KMS_KEY", "CUSTOMER_MANAGED_KEY"] } } }] },
    "p_kms_key": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "IdentityCenterKmsKeyArn" }, "ParameterValue": { "type": "string", "pattern": "^$|^arn:aws:kms:us-east-1:839393571433:key/[0-9a-fA-F-]{36}$" } } }] },
    "p_boto3": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "ExpectedBoto3Version" }, "ParameterValue": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" } } }] },
    "p_botocore": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "ExpectedBotocoreVersion" }, "ParameterValue": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" } } }] },
    "p_repair_bucket": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairArtifactBucket" }, "ParameterValue": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$" } } }] },
    "p_repair_key": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairArtifactKey" }, "ParameterValue": { "type": "string", "pattern": "^scanalyze/platform-authority/gug-221/signed/[0-9a-f-]{36}\\.zip$" } } }] },
    "p_repair_version": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairArtifactVersion" }, "ParameterValue": { "type": "string", "minLength": 1, "maxLength": 1024 } } }] },
    "p_repair_sha": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "RepairArtifactCodeSha256" }, "ParameterValue": { "$ref": "#/$defs/lambda_digest" } } }] },
    "p_reconcile_bucket": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "ReconcileArtifactBucket" }, "ParameterValue": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$" } } }] },
    "p_reconcile_key": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "ReconcileArtifactKey" }, "ParameterValue": { "type": "string", "pattern": "^scanalyze/platform-authority/gug-221/signed/[0-9a-f-]{36}\\.zip$" } } }] },
    "p_reconcile_version": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "ReconcileArtifactVersion" }, "ParameterValue": { "type": "string", "minLength": 1, "maxLength": 1024 } } }] },
    "p_reconcile_sha": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "ReconcileArtifactCodeSha256" }, "ParameterValue": { "$ref": "#/$defs/lambda_digest" } } }] },
    "p_signing_profile": { "allOf": [{ "$ref": "#/$defs/parameter" }, { "properties": { "ParameterKey": { "const": "SigningProfileVersionArn" }, "ParameterValue": { "type": "string", "pattern": "^arn:aws:signer:us-east-1:042360977644:/signing-profiles/[A-Za-z0-9_]{2,64}/[A-Za-z0-9]{10}$" } } }] }
  }
}
