{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/contract-platform.v2.schema.json",
  "title": "Scanalyze container platform outputs v2",
  "type": "object",
  "required": [
    "ecs_cluster_arn",
    "ecs_cluster_name",
    "alb_arn",
    "alb_dns_name",
    "alb_listener_arn",
    "alb_security_group_id"
  ],
  "additionalProperties": false,
  "properties": {
    "ecs_cluster_arn": { "type": "string", "pattern": "^arn:[^:]+:ecs:[^:]+:[0-9]{12}:cluster/.+$" },
    "ecs_cluster_name": { "type": "string", "minLength": 1 },
    "alb_arn": { "type": "string", "pattern": "^arn:[^:]+:elasticloadbalancing:[^:]+:[0-9]{12}:loadbalancer/.+$" },
    "alb_dns_name": { "type": "string", "minLength": 1 },
    "alb_listener_arn": { "type": "string", "pattern": "^arn:[^:]+:elasticloadbalancing:[^:]+:[0-9]{12}:listener/.+$" },
    "alb_security_group_id": { "type": "string", "pattern": "^sg-[0-9a-f]+$" }
  }
}
