{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scanalyze.contract.platform.v1",
  "title": "Platform Layer Contract Outputs",
  "type": "object",
  "required": ["ecs_cluster_arn", "alb_arn", "alb_dns_name", "alb_listener_arn", "alb_sg_id", "ecs_task_sg_id"],
  "additionalProperties": false,
  "properties": {
    "ecs_cluster_arn": { "type": "string", "pattern": "^arn:aws:ecs:[a-z0-9-]+:[0-9]{12}:cluster/.+$" },
    "alb_arn": { "type": "string", "pattern": "^arn:aws:elasticloadbalancing:[a-z0-9-]+:[0-9]{12}:loadbalancer/.+$" },
    "alb_dns_name": { "type": "string" },
    "alb_hosted_zone_id": { "type": "string" },
    "alb_listener_arn": { "type": "string", "pattern": "^arn:aws:elasticloadbalancing:[a-z0-9-]+:[0-9]{12}:listener/.+$" },
    "target_group_arns": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scanalyze-ingest-api": { "type": "string", "pattern": "^arn:aws:elasticloadbalancing:.+$" }
      }
    },
    "alb_sg_id": { "type": "string", "pattern": "^sg-[a-f0-9]+$" },
    "ecs_task_sg_id": { "type": "string", "pattern": "^sg-[a-f0-9]+$" }
  }
}
