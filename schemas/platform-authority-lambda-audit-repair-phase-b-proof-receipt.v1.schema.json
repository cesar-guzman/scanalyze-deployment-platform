{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-phase-b-proof-receipt.v1.schema.json",
  "title": "GUG-221 Phase B Proof-Only Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "environment",
    "production",
    "status",
    "binding_digest",
    "managed_policy_arn",
    "managed_policy_version",
    "managed_policy_digest",
    "proof_required_action",
    "direct_effect_action",
    "direct_effect_status",
    "expected_user_id_digest",
    "proof_role_arn_digest",
    "proof_session_arn_digest",
    "token_pair_digest",
    "phase_b_intent_digest",
    "change_set_receipt_digest",
    "execution_request_digest",
    "template_digest",
    "parameters_digest",
    "resource_inventory_digest",
    "ledger_controls_digest",
    "broker_topology_sha256",
    "broker_topology_provider_evidence_digest",
    "invoker_policy_sha256",
    "broker_policy_sha256",
    "proof_policy_sha256",
    "application_actor_policy_sha256",
    "proof_expires_at",
    "provided_context_count",
    "provided_context_provider_arn",
    "identity_context_user_binding",
    "id_token_serialized",
    "identity_context_serialized",
    "credentials_exposed",
    "credentials_consumed_for_effect",
    "live_effect_authorized",
    "native_on_behalf_of",
    "receipt_digest"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "record_type": {"const": "platform_authority_lambda_audit_repair_phase_b_proof_receipt"},
    "environment": {"const": "non-production"},
    "production": {"const": false},
    "status": {"const": "IDENTITY_CONTEXT_PROOF_VERIFIED"},
    "binding_digest": {"$ref": "#/$defs/digest"},
    "managed_policy_arn": {"const": "arn:aws:iam::aws:policy/AWSIAMIdentityCenterAllowListForIdentityContext"},
    "managed_policy_version": {"const": "v12"},
    "managed_policy_digest": {"const": "sha256:588e10587ff62c683615a9612b1f42ded9fccd03bd94810dc6760dad50665655"},
    "proof_required_action": {"const": "sts:SetContext"},
    "direct_effect_action": {"const": "cloudformation:ExecuteChangeSet"},
    "direct_effect_status": {"const": "BLOCKED_BY_AWS_IDENTITY_CONTEXT_V12"},
    "expected_user_id_digest": {"$ref": "#/$defs/digest"},
    "proof_role_arn_digest": {"$ref": "#/$defs/digest"},
    "proof_session_arn_digest": {"$ref": "#/$defs/digest"},
    "token_pair_digest": {"$ref": "#/$defs/digest"},
    "phase_b_intent_digest": {"$ref": "#/$defs/digest"},
    "change_set_receipt_digest": {"$ref": "#/$defs/digest"},
    "execution_request_digest": {"$ref": "#/$defs/digest"},
    "template_digest": {"$ref": "#/$defs/digest"},
    "parameters_digest": {"$ref": "#/$defs/digest"},
    "resource_inventory_digest": {"$ref": "#/$defs/digest"},
    "ledger_controls_digest": {"$ref": "#/$defs/digest"},
    "broker_topology_sha256": {"$ref": "#/$defs/digest"},
    "broker_topology_provider_evidence_digest": {"$ref": "#/$defs/nonzero_digest"},
    "invoker_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "broker_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "proof_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "application_actor_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "proof_expires_at": {"$ref": "#/$defs/timestamp"},
    "provided_context_count": {"const": 1},
    "provided_context_provider_arn": {"const": "arn:aws:iam::aws:contextProvider/IdentityCenter"},
    "identity_context_user_binding": {"const": "VERIFIED_BY_EXACT_STS_SET_CONTEXT_TRUST"},
    "id_token_serialized": {"const": false},
    "identity_context_serialized": {"const": false},
    "credentials_exposed": {"const": false},
    "credentials_consumed_for_effect": {"const": false},
    "live_effect_authorized": {"const": false},
    "native_on_behalf_of": {"const": false},
    "receipt_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nonzero_digest": {"type": "string", "pattern": "^sha256:(?!0{64})[0-9a-f]{64}$"},
    "raw_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time", "pattern": "Z$"}
  }
}
