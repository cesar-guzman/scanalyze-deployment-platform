{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-identity-enhanced-session-receipt.v1.schema.json",
  "title": "Platform Authority Identity-Enhanced Session Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "environment",
    "production",
    "status",
    "binding_digest",
    "managed_policy_version",
    "managed_policy_digest",
    "required_action",
    "role_kind",
    "broker_alias",
    "expected_user_id_digest",
    "source_role_arn_digest",
    "target_role_arn_digest",
    "expires_at",
    "token_issued",
    "sts_session_issued",
    "session_consumed",
    "broker_invocation_performed",
    "live_retirement_authorized",
    "receipt_digest"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "record_type": { "const": "platform_authority_identity_enhanced_session_receipt" },
    "environment": { "const": "non-production" },
    "production": { "const": false },
    "status": { "const": "IDENTITY_ENHANCED_SESSION_CONSUMED" },
    "binding_digest": { "$ref": "#/$defs/digest" },
    "managed_policy_version": { "type": "string", "pattern": "^v[A-Za-z0-9]+$" },
    "managed_policy_digest": { "$ref": "#/$defs/digest" },
    "required_action": { "const": "lambda:InvokeFunction" },
    "role_kind": { "enum": ["classifier", "approver"] },
    "broker_alias": { "enum": ["classify", "retire", "reconcile"] },
    "expected_user_id_digest": { "$ref": "#/$defs/digest" },
    "source_role_arn_digest": { "$ref": "#/$defs/digest" },
    "target_role_arn_digest": { "$ref": "#/$defs/digest" },
    "expires_at": { "$ref": "#/$defs/timestamp" },
    "token_issued": { "const": true },
    "sts_session_issued": { "const": true },
    "session_consumed": { "const": true },
    "broker_invocation_performed": { "const": false },
    "live_retirement_authorized": { "const": false },
    "receipt_digest": { "$ref": "#/$defs/digest" }
  },
  "allOf": [
    {
      "if": { "properties": { "role_kind": { "const": "classifier" } } },
      "then": { "properties": { "broker_alias": { "const": "classify" } } }
    },
    {
      "if": { "properties": { "role_kind": { "const": "approver" } } },
      "then": { "properties": { "broker_alias": { "enum": ["retire", "reconcile"] } } }
    }
  ],
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    }
  }
}
