{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-phase-b-precondition-change-set-receipt.v1.schema.json",
  "title": "GUG-221 pre-Phase-B broker Change Set read-only receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "work_package",
    "phase",
    "source_commit",
    "signed_artifact_receipt_sha256",
    "reviewed_package_manifest_sha256",
    "phase_b_identity_materialization_receipt_sha256",
    "pep_parameter_handoff_sha256",
    "pep_change_set_receipt_sha256",
    "parameter_handoff_sha256",
    "reviewed_template_sha256",
    "reviewed_policy_sha256",
    "broker_topology_sha256",
    "change_set",
    "verifier",
    "evaluated_at",
    "evidence_status",
    "authority_status",
    "production_status",
    "receipt_digest"
  ],
  "properties": {
    "artifact_type": {
      "const": "scanalyze.platform_authority.lambda_audit_repair_phase_b_precondition_change_set_receipt.v1"
    },
    "schema_version": { "const": 1 },
    "work_package": { "const": "GUG-221" },
    "phase": { "const": "PRE_B_BROKER_CHANGE_SET" },
    "source_commit": { "$ref": "#/$defs/commit" },
    "signed_artifact_receipt_sha256": { "$ref": "#/$defs/raw_digest" },
    "reviewed_package_manifest_sha256": { "$ref": "#/$defs/raw_digest" },
    "phase_b_identity_materialization_receipt_sha256": { "$ref": "#/$defs/raw_digest" },
    "pep_parameter_handoff_sha256": { "$ref": "#/$defs/raw_digest" },
    "pep_change_set_receipt_sha256": { "$ref": "#/$defs/raw_digest" },
    "parameter_handoff_sha256": { "$ref": "#/$defs/raw_digest" },
    "reviewed_template_sha256": { "$ref": "#/$defs/raw_digest" },
    "reviewed_policy_sha256": { "$ref": "#/$defs/reviewed_policy_sha256" },
    "broker_topology_sha256": { "$ref": "#/$defs/prefixed_digest" },
    "change_set": { "$ref": "#/$defs/change_set" },
    "verifier": { "$ref": "#/$defs/verifier" },
    "evaluated_at": { "$ref": "#/$defs/timestamp" },
    "evidence_status": { "const": "PRE_B_CHANGE_SET_READ_ONLY_VERIFIED" },
    "authority_status": {
      "const": "REVIEW_EVIDENCE_ONLY_NOT_EXECUTION_AUTHORITY"
    },
    "production_status": { "const": "NO-GO" },
    "receipt_digest": { "$ref": "#/$defs/raw_digest" }
  },
  "$defs": {
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "raw_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "prefixed_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "stack_tags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment",
        "managed_by",
        "production",
        "service",
        "source_commit",
        "work_package"
      ],
      "properties": {
        "environment": { "const": "non-production" },
        "managed_by": { "const": "cloudformation" },
        "production": { "const": "false" },
        "service": { "const": "scanalyze-platform-authority" },
        "source_commit": { "$ref": "#/$defs/commit" },
        "work_package": { "const": "GUG-221" }
      }
    },
    "reviewed_policy_sha256": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "InvokerPolicySha256",
        "BrokerPolicySha256",
        "ProofPolicySha256",
        "ApplicationActorPolicySha256"
      ],
      "properties": {
        "InvokerPolicySha256": { "$ref": "#/$defs/raw_digest" },
        "BrokerPolicySha256": { "$ref": "#/$defs/raw_digest" },
        "ProofPolicySha256": { "$ref": "#/$defs/raw_digest" },
        "ApplicationActorPolicySha256": { "$ref": "#/$defs/raw_digest" }
      }
    },
    "create_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "event_time", "event_digest"],
      "properties": {
        "event_id": { "$ref": "#/$defs/uuid" },
        "event_time": { "$ref": "#/$defs/timestamp" },
        "event_digest": { "$ref": "#/$defs/raw_digest" }
      }
    },
    "resource_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_resource_id",
        "resource_type",
        "action",
        "replacement"
      ],
      "properties": {
        "logical_resource_id": { "type": "string" },
        "resource_type": { "type": "string" },
        "action": { "const": "Add" },
        "replacement": { "const": "False" }
      }
    },
    "r_broker_event_config": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": {
              "const": "PhaseBBrokerEventInvokeConfig"
            },
            "resource_type": { "const": "AWS::Lambda::EventInvokeConfig" }
          }
        }
      ]
    },
    "r_broker_alias": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": { "const": "PhaseBBrokerExecuteAlias" },
            "resource_type": { "const": "AWS::Lambda::Alias" }
          }
        }
      ]
    },
    "r_broker_role": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": { "const": "PhaseBBrokerExecutionRole" },
            "resource_type": { "const": "AWS::IAM::Role" }
          }
        }
      ]
    },
    "r_broker_function": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": { "const": "PhaseBBrokerFunction" },
            "resource_type": { "const": "AWS::Lambda::Function" }
          }
        }
      ]
    },
    "r_broker_permission": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": {
              "const": "PhaseBBrokerInvokePermission"
            },
            "resource_type": { "const": "AWS::Lambda::Permission" }
          }
        }
      ]
    },
    "r_broker_log_group": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": { "const": "PhaseBBrokerLogGroup" },
            "resource_type": { "const": "AWS::Logs::LogGroup" }
          }
        }
      ]
    },
    "r_broker_version": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": { "const": "PhaseBBrokerVersion" },
            "resource_type": { "const": "AWS::Lambda::Version" }
          }
        }
      ]
    },
    "r_execution_ledger": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": { "const": "PhaseBExecutionLedger" },
            "resource_type": { "const": "AWS::DynamoDB::Table" }
          }
        }
      ]
    },
    "r_proof_role": {
      "allOf": [
        { "$ref": "#/$defs/resource_change" },
        {
          "properties": {
            "logical_resource_id": { "const": "PhaseBProofRole" },
            "resource_type": { "const": "AWS::IAM::Role" }
          }
        }
      ]
    },
    "change_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "arn",
        "uuid",
        "name",
        "stack_arn",
        "stack_name",
        "type",
        "status",
        "execution_status",
        "on_stack_failure",
        "capabilities",
        "tags",
        "parameters_sha256",
        "resource_changes",
        "create_event"
      ],
      "properties": {
        "arn": {
          "type": "string",
          "pattern": "^arn:aws:cloudformation:us-east-1:042360977644:changeSet/gug221-phase-b-broker-pep-create/[0-9a-fA-F-]{36}$"
        },
        "uuid": { "$ref": "#/$defs/uuid" },
        "name": { "const": "gug221-phase-b-broker-pep-create" },
        "stack_arn": {
          "type": "string",
          "pattern": "^arn:aws:cloudformation:us-east-1:042360977644:stack/scanalyze-platform-authority-gug221-phase-b-broker-pep/[0-9a-fA-F-]{36}$"
        },
        "stack_name": {
          "const": "scanalyze-platform-authority-gug221-phase-b-broker-pep"
        },
        "type": { "const": "CREATE" },
        "status": { "const": "CREATE_COMPLETE" },
        "execution_status": { "const": "AVAILABLE" },
        "on_stack_failure": { "const": "ROLLBACK" },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "prefixItems": [{ "const": "CAPABILITY_NAMED_IAM" }],
          "items": false
        },
        "tags": { "$ref": "#/$defs/stack_tags" },
        "parameters_sha256": { "$ref": "#/$defs/raw_digest" },
        "resource_changes": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "uniqueItems": true,
          "prefixItems": [
            { "$ref": "#/$defs/r_broker_event_config" },
            { "$ref": "#/$defs/r_broker_alias" },
            { "$ref": "#/$defs/r_broker_role" },
            { "$ref": "#/$defs/r_broker_function" },
            { "$ref": "#/$defs/r_broker_permission" },
            { "$ref": "#/$defs/r_broker_log_group" },
            { "$ref": "#/$defs/r_broker_version" },
            { "$ref": "#/$defs/r_execution_ledger" },
            { "$ref": "#/$defs/r_proof_role" }
          ],
          "items": false
        },
        "create_event": { "$ref": "#/$defs/create_event" }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "account_id", "caller_arn"],
      "properties": {
        "profile": { "const": "042360977644_ReadOnlyAccess" },
        "account_id": { "const": "042360977644" },
        "caller_arn": {
          "type": "string",
          "pattern": "^arn:aws:sts::042360977644:assumed-role/AWSReservedSSO_AWSReadOnlyAccess_[0-9a-f]{16}/[A-Za-z0-9+=,.@_-]{1,64}$"
        }
      }
    }
  }
}
