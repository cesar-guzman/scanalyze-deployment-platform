{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/saved-plan-approval.v1.schema.json",
  "title": "Scanalyze Independent Saved-Plan Approval v1",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "customer_id",
    "deployment_id",
    "account_id",
    "region",
    "environment",
    "execution_id",
    "change_id",
    "layer",
    "plan_record_digest",
    "repository_owner_id",
    "repository_id",
    "workflow_ref",
    "workflow_sha",
    "workflow_run_id",
    "github_environment",
    "environment_configuration_digest",
    "initiator_user_id",
    "approver_user_id",
    "decision",
    "approved_at",
    "expires_at",
    "approval_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "record_type": { "const": "saved_plan_approval" },
    "customer_id": { "$ref": "#/$defs/customer_id" },
    "deployment_id": { "$ref": "#/$defs/deployment_id" },
    "account_id": { "$ref": "#/$defs/account_id" },
    "region": { "$ref": "#/$defs/region" },
    "environment": { "enum": ["sandbox", "dev", "staging"] },
    "execution_id": { "type": "string", "pattern": "^exec_[0-9A-HJKMNP-TV-Z]{26}$" },
    "change_id": { "type": "string", "pattern": "^chg_[0-9A-HJKMNP-TV-Z]{26}$" },
    "layer": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "plan_record_digest": { "$ref": "#/$defs/digest" },
    "repository_owner_id": { "type": "integer", "minimum": 1 },
    "repository_id": { "type": "integer", "minimum": 1 },
    "workflow_ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/\\.github/workflows/nonprod-release\\.yml@refs/heads/main$"
    },
    "workflow_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "workflow_run_id": { "type": "integer", "minimum": 1 },
    "github_environment": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$" },
    "environment_configuration_digest": { "$ref": "#/$defs/digest" },
    "initiator_user_id": { "type": "integer", "minimum": 1 },
    "approver_user_id": { "type": "integer", "minimum": 1 },
    "decision": { "const": "APPROVED" },
    "approved_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "approval_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "customer_id": { "type": "string", "pattern": "^cust_[0-9A-HJKMNP-TV-Z]{26}$" },
    "deployment_id": { "type": "string", "pattern": "^dep_[0-9A-HJKMNP-TV-Z]{26}$" },
    "account_id": { "type": "string", "pattern": "^(?!000000000000$)[0-9]{12}$" },
    "region": { "type": "string", "pattern": "^[a-z]{2}(?:-[a-z]+)+-[0-9]+$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
