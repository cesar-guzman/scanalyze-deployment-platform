{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-delegation-live-receipt.v1.schema.json",
  "title": "GUG-221 Phase A provider-derived delegation live receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type", "schema_version", "work_package", "phase", "source_commit",
    "deployment_contract_sha256", "gug220_intent_sha256",
    "gug220_ledger_sha256", "gug220_receipt_sha256",
    "gug220_evidence_sha256", "gug220_provider_state_sha256",
    "delegation_handoff_sha256", "delegation_change_set_receipt",
    "delegation_change_set_receipt_sha256", "delegation_execution_receipt",
    "delegation_execution_receipt_sha256", "template_sha256", "stack_arn",
    "stack_parameters_sha256", "stack_tags", "stack_outputs",
    "stack_resources_sha256", "repair_invoker_permission_set_arn",
    "repair_invoker_permission_set_sha256", "repair_invoker_policy_sha256",
    "repair_invoker_assignment_sha256", "management_roles",
    "pending_operations_before", "pending_operations_after",
    "provider_state_sha256", "verifier", "evaluated_at", "evidence_status",
    "authority_status", "production_status"
  ],
  "properties": {
    "artifact_type": { "const": "scanalyze.platform_authority.lambda_audit_repair_delegation_live_receipt.v1" },
    "schema_version": { "const": 1 }, "work_package": { "const": "GUG-221" },
    "phase": { "const": "A_DELEGATION_LIVE_READBACK" },
    "source_commit": { "$ref": "#/$defs/commit" },
    "deployment_contract_sha256": { "$ref": "#/$defs/digest" },
    "gug220_intent_sha256": { "$ref": "#/$defs/digest" },
    "gug220_ledger_sha256": { "$ref": "#/$defs/digest" },
    "gug220_receipt_sha256": { "$ref": "#/$defs/digest" },
    "gug220_evidence_sha256": { "$ref": "#/$defs/digest" },
    "gug220_provider_state_sha256": { "$ref": "#/$defs/digest" },
    "delegation_handoff_sha256": { "$ref": "#/$defs/digest" },
    "delegation_change_set_receipt": { "$ref": "#/$defs/embedded_change_set_receipt" },
    "delegation_change_set_receipt_sha256": { "$ref": "#/$defs/digest" },
    "delegation_execution_receipt": { "$ref": "#/$defs/embedded_execution_receipt" },
    "delegation_execution_receipt_sha256": { "$ref": "#/$defs/digest" },
    "template_sha256": { "$ref": "#/$defs/digest" },
    "stack_arn": { "type": "string", "pattern": "^arn:aws:cloudformation:us-east-1:839393571433:stack/scanalyze-platform-authority-lambda-audit-repair-delegation/[0-9a-fA-F-]{36}$" },
    "stack_parameters_sha256": { "$ref": "#/$defs/digest" },
    "stack_tags": { "$ref": "#/$defs/stack_tags" },
    "stack_outputs": {
      "type": "object", "additionalProperties": false,
      "required": ["MutationServiceRoleArn", "ReadbackServiceRoleArn", "RepairInvokerPermissionSetArn", "RepairPrincipalIdDigestRequired", "ProductionAuthorized"],
      "properties": {
        "MutationServiceRoleArn": { "const": "arn:aws:iam::839393571433:role/scanalyze/platform-authority/ScanalyzeLambdaAuditRepairMutationServiceRole" },
        "ReadbackServiceRoleArn": { "const": "arn:aws:iam::839393571433:role/scanalyze/platform-authority/ScanalyzeLambdaAuditRepairReadbackServiceRole" },
        "RepairInvokerPermissionSetArn": { "$ref": "#/$defs/permission_set_arn" },
        "RepairPrincipalIdDigestRequired": { "const": "true" },
        "ProductionAuthorized": { "const": "false" }
      }
    },
    "stack_resources_sha256": { "$ref": "#/$defs/digest" },
    "repair_invoker_permission_set_arn": { "$ref": "#/$defs/permission_set_arn" },
    "repair_invoker_permission_set_sha256": { "$ref": "#/$defs/digest" },
    "repair_invoker_policy_sha256": { "$ref": "#/$defs/digest" },
    "repair_invoker_assignment_sha256": { "$ref": "#/$defs/digest" },
    "management_roles": {
      "type": "array", "minItems": 2, "maxItems": 2,
      "prefixItems": [{ "$ref": "#/$defs/mutation_role" }, { "$ref": "#/$defs/readback_role" }],
      "items": false
    },
    "pending_operations_before": { "$ref": "#/$defs/pending_operations" },
    "pending_operations_after": { "$ref": "#/$defs/pending_operations" },
    "provider_state_sha256": { "$ref": "#/$defs/digest" },
    "verifier": { "$ref": "#/$defs/management_verifier" },
    "evaluated_at": { "$ref": "#/$defs/timestamp" },
    "evidence_status": { "const": "DELEGATION_LIVE_READ_ONLY_VERIFIED" },
    "authority_status": { "const": "PROVIDER_DERIVED_NOT_EXECUTION_AUTHORITY" },
    "production_status": { "const": "NO-GO" }
  },
  "$defs": {
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "permission_set_arn": { "type": "string", "pattern": "^arn:aws:sso:::permissionSet/ssoins-[A-Za-z0-9]{16}/ps-[A-Za-z0-9]{16}$" },
    "stack_tags": {
      "type": "object", "additionalProperties": false,
      "required": ["environment", "managed_by", "production", "service", "source_commit", "work_package"],
      "properties": {
        "environment": { "const": "non-production" }, "managed_by": { "const": "cloudformation" },
        "production": { "const": "false" }, "service": { "const": "scanalyze-platform-authority" },
        "source_commit": { "$ref": "#/$defs/commit" }, "work_package": { "const": "GUG-221" }
      }
    },
    "pending_operations": {
      "type": "object", "additionalProperties": false,
      "required": ["assignment_creations", "assignment_deletions", "permission_set_provisioning"],
      "properties": {
        "assignment_creations": { "const": [] },
        "assignment_deletions": { "const": [] },
        "permission_set_provisioning": { "const": [] }
      }
    },
    "embedded_change_set_receipt": {
      "type": "object", "additionalProperties": false,
      "required": [
        "artifact_type", "schema_version", "work_package", "phase",
        "source_commit", "deployment_contract_sha256", "gug220_intent_sha256",
        "gug220_ledger_sha256", "gug220_receipt_sha256",
        "gug220_evidence_sha256", "gug220_provider_state_sha256",
        "parameter_handoff_sha256", "template_sha256", "change_set",
        "execution_contract", "verifier", "evaluated_at", "evidence_status",
        "authority_status", "production_status"
      ],
      "properties": {
        "artifact_type": { "const": "scanalyze.platform_authority.lambda_audit_repair_delegation_change_set_receipt.v1" },
        "schema_version": { "const": 1 }, "work_package": { "const": "GUG-221" },
        "phase": { "const": "A_DELEGATION_CHANGE_SET" },
        "source_commit": {}, "deployment_contract_sha256": {}, "gug220_intent_sha256": {},
        "gug220_ledger_sha256": {}, "gug220_receipt_sha256": {},
        "gug220_evidence_sha256": {}, "gug220_provider_state_sha256": {},
        "parameter_handoff_sha256": {}, "template_sha256": {}, "change_set": {},
        "execution_contract": {}, "verifier": {}, "evaluated_at": {},
        "evidence_status": { "const": "DELEGATION_CHANGE_SET_READ_ONLY_VERIFIED" },
        "authority_status": { "const": "REVIEW_EVIDENCE_ONLY_NOT_EXECUTION_AUTHORITY" },
        "production_status": { "const": "NO-GO" }
      }
    },
    "embedded_execution_receipt": {
      "type": "object", "additionalProperties": false,
      "required": [
        "artifact_type", "schema_version", "work_package", "phase",
        "source_commit", "deployment_contract_sha256",
        "delegation_change_set_receipt_sha256", "change_set_arn",
        "change_set_uuid", "stack_arn", "client_request_token",
        "client_request_token_sha256", "execute_request_sha256",
        "executor_arn_sha256", "execute_event", "stack_event_count",
        "stack_events_sha256", "terminal_resources", "executed_at",
        "stack_completed_at", "verifier", "evaluated_at", "evidence_status",
        "authority_status", "production_status"
      ],
      "properties": {
        "artifact_type": { "const": "scanalyze.platform_authority.lambda_audit_repair_delegation_execution_receipt.v1" },
        "schema_version": { "const": 1 }, "work_package": { "const": "GUG-221" },
        "phase": { "const": "A_DELEGATION_EXECUTION_TRACE" },
        "source_commit": {}, "deployment_contract_sha256": {},
        "delegation_change_set_receipt_sha256": {}, "change_set_arn": {},
        "change_set_uuid": {}, "stack_arn": {},
        "client_request_token": { "type": "string", "pattern": "^gug221-a-[0-9a-f]{48}$" },
        "client_request_token_sha256": {}, "execute_request_sha256": {},
        "executor_arn_sha256": {}, "execute_event": {}, "stack_event_count": {},
        "stack_events_sha256": {}, "terminal_resources": {}, "executed_at": {},
        "stack_completed_at": {}, "verifier": {}, "evaluated_at": {},
        "evidence_status": { "const": "DELEGATION_EXECUTION_READ_ONLY_VERIFIED" },
        "authority_status": { "const": "PROVIDER_DERIVED_EXECUTION_TRACE_NOT_EXECUTION_AUTHORITY" },
        "production_status": { "const": "NO-GO" }
      }
    },
    "role": {
      "type": "object", "additionalProperties": false,
      "required": ["account_id", "role_name", "path", "arn", "max_session_duration", "trust_policy_digest", "inline_policy_name", "inline_policy_digest", "attached_managed_policy_arns", "permissions_boundary_arn"],
      "properties": {
        "account_id": { "const": "839393571433" }, "role_name": { "type": "string" },
        "path": { "const": "/scanalyze/platform-authority/" }, "arn": { "type": "string" },
        "max_session_duration": { "const": 3600 }, "trust_policy_digest": { "$ref": "#/$defs/digest" },
        "inline_policy_name": { "type": "string" }, "inline_policy_digest": { "$ref": "#/$defs/digest" },
        "attached_managed_policy_arns": { "const": [] }, "permissions_boundary_arn": { "type": "null" }
      }
    },
    "mutation_role": {
      "allOf": [{ "$ref": "#/$defs/role" }, { "properties": {
        "role_name": { "const": "ScanalyzeLambdaAuditRepairMutationServiceRole" },
        "arn": { "const": "arn:aws:iam::839393571433:role/scanalyze/platform-authority/ScanalyzeLambdaAuditRepairMutationServiceRole" },
        "inline_policy_name": { "const": "Gug221ExactRepairMutations" }
      } }]
    },
    "readback_role": {
      "allOf": [{ "$ref": "#/$defs/role" }, { "properties": {
        "role_name": { "const": "ScanalyzeLambdaAuditRepairReadbackServiceRole" },
        "arn": { "const": "arn:aws:iam::839393571433:role/scanalyze/platform-authority/ScanalyzeLambdaAuditRepairReadbackServiceRole" },
        "inline_policy_name": { "const": "Gug221ExactReadback" }
      } }]
    },
    "management_verifier": {
      "type": "object", "additionalProperties": false,
      "required": ["profile", "account_id", "caller_arn"],
      "properties": {
        "profile": { "const": "839393571433_ReadOnlyAccess" }, "account_id": { "const": "839393571433" },
        "caller_arn": { "type": "string", "pattern": "^arn:aws:sts::839393571433:assumed-role/AWSReservedSSO_AWSReadOnlyAccess_[0-9a-f]{16}/[A-Za-z0-9+=,.@_-]{1,64}$" }
      }
    }
  }
}
