{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-provisioning-intent.v1.schema.json",
  "title": "Platform Authority Lambda Audit Provisioning Intent v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "environment",
    "production",
    "management_account_id_digest",
    "authority_account_id_digest",
    "target_region",
    "identity_center_region",
    "identity_center_instance_arn_digest",
    "identity_store_id_digest",
    "saml_provider_arn_digest",
    "source_commit",
    "execution_ledger_directory_digest",
    "permission_set_name",
    "permission_set_description",
    "session_duration",
    "relay_state_present",
    "expected_tags_digest",
    "inline_policy_template_sha256",
    "collector_inline_policy_digest",
    "managed_policy_arns",
    "customer_managed_policy_references",
    "permissions_boundary_present",
    "principal_type",
    "principal_id_digest",
    "direct_assignment_count",
    "provisioned_account_count",
    "expected_mutations",
    "independent_review_present",
    "approval_authorized",
    "protected_retirement_authorized",
    "lambda_invocation_authorized",
    "customer_deployment_authorized",
    "production_authorized",
    "created_at",
    "expires_at",
    "intent_digest"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "record_type": { "const": "platform_authority_lambda_audit_provisioning_intent" },
    "environment": { "const": "non-production" },
    "production": { "const": false },
    "management_account_id_digest": { "$ref": "#/$defs/digest" },
    "authority_account_id_digest": { "$ref": "#/$defs/digest" },
    "target_region": { "const": "us-east-1" },
    "identity_center_region": { "const": "us-east-1" },
    "identity_center_instance_arn_digest": { "$ref": "#/$defs/digest" },
    "identity_store_id_digest": { "$ref": "#/$defs/digest" },
    "saml_provider_arn_digest": { "$ref": "#/$defs/digest" },
    "source_commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "execution_ledger_directory_digest": { "$ref": "#/$defs/digest" },
    "permission_set_name": { "const": "ScanalyzeAuthorityLambdaAudit" },
    "permission_set_description": {
      "const": "GUG-219 read-only account-wide Lambda invocation-authority inventory"
    },
    "session_duration": { "const": "PT1H" },
    "relay_state_present": { "const": false },
    "expected_tags_digest": { "$ref": "#/$defs/digest" },
    "inline_policy_template_sha256": { "$ref": "#/$defs/digest" },
    "collector_inline_policy_digest": { "$ref": "#/$defs/digest" },
    "managed_policy_arns": { "type": "array", "maxItems": 0, "items": false },
    "customer_managed_policy_references": {
      "type": "array",
      "maxItems": 0,
      "items": false
    },
    "permissions_boundary_present": { "const": false },
    "principal_type": { "const": "USER" },
    "principal_id_digest": { "$ref": "#/$defs/digest" },
    "direct_assignment_count": { "const": 1 },
    "provisioned_account_count": { "const": 1 },
    "expected_mutations": {
      "type": "array",
      "prefixItems": [
        { "const": "sso-admin:CreatePermissionSet" },
        { "const": "sso-admin:PutInlinePolicyToPermissionSet" },
        { "const": "sso-admin:CreateAccountAssignment" },
        { "const": "sso-admin:ProvisionPermissionSet" }
      ],
      "items": false,
      "minItems": 4,
      "maxItems": 4
    },
    "independent_review_present": { "const": false },
    "approval_authorized": { "const": false },
    "protected_retirement_authorized": { "const": false },
    "lambda_invocation_authorized": { "const": false },
    "customer_deployment_authorized": { "const": false },
    "production_authorized": { "const": false },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "expires_at": { "$ref": "#/$defs/timestamp" },
    "intent_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    }
  }
}
