{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-phase-b-broker-effect-receipt.v1.schema.json",
  "title": "GUG-221 Phase B Broker Effect Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "environment",
    "production",
    "status",
    "execution_id",
    "binding_digest",
    "proof_receipt_digest",
    "ledger_digest",
    "closure_pending_receipt_digest",
    "execution_request_digest",
    "broker_topology_sha256",
    "broker_topology_provider_evidence_digest",
    "invoker_policy_sha256",
    "broker_policy_sha256",
    "proof_policy_sha256",
    "application_actor_policy_sha256",
    "stack_arn",
    "change_set_arn",
    "client_request_token",
    "effect_principal_type",
    "effect_principal_arn",
    "proof_credentials_used_for_effect",
    "attempts",
    "execution_ambiguous",
    "retry_permitted",
    "one_shot_execution_gate_consumed",
    "native_on_behalf_of",
    "provider_revocation_pending",
    "authority_revoked",
    "production_status",
    "receipt_digest"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "record_type": {"const": "platform_authority_lambda_audit_repair_phase_b_broker_effect_receipt"},
    "environment": {"const": "non-production"},
    "production": {"const": false},
    "status": {"enum": ["DISPATCH_ACCEPTED", "UNCERTAIN_RECONCILE_ONLY"]},
    "execution_id": {"type": "string", "pattern": "^gug221-phase-b-[0-9a-f]{64}$"},
    "binding_digest": {"$ref": "#/$defs/digest"},
    "proof_receipt_digest": {"$ref": "#/$defs/digest"},
    "ledger_digest": {"$ref": "#/$defs/digest"},
    "closure_pending_receipt_digest": {"$ref": "#/$defs/digest"},
    "execution_request_digest": {"$ref": "#/$defs/digest"},
    "broker_topology_sha256": {"$ref": "#/$defs/digest"},
    "broker_topology_provider_evidence_digest": {"$ref": "#/$defs/nonzero_digest"},
    "invoker_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "broker_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "proof_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "application_actor_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "stack_arn": {"$ref": "#/$defs/stack_arn"},
    "change_set_arn": {"$ref": "#/$defs/change_set_arn"},
    "client_request_token": {"$ref": "#/$defs/client_token"},
    "effect_principal_type": {"const": "AWS_SERVICE_ROLE"},
    "effect_principal_arn": {"const": "arn:aws:iam::042360977644:role/ScanalyzeGug221PhaseBBrokerExecution"},
    "proof_credentials_used_for_effect": {"const": false},
    "attempts": {"const": 1},
    "execution_ambiguous": {"type": "boolean"},
    "retry_permitted": {"const": false},
    "one_shot_execution_gate_consumed": {"const": true},
    "native_on_behalf_of": {"const": false},
    "provider_revocation_pending": {"const": true},
    "authority_revoked": {"const": false},
    "production_status": {"const": "NO-GO"},
    "receipt_digest": {"$ref": "#/$defs/digest"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "DISPATCH_ACCEPTED"}}, "required": ["status"]},
      "then": {"properties": {"execution_ambiguous": {"const": false}}}
    },
    {
      "if": {"properties": {"status": {"const": "UNCERTAIN_RECONCILE_ONLY"}}, "required": ["status"]},
      "then": {"properties": {"execution_ambiguous": {"const": true}}}
    }
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nonzero_digest": {"type": "string", "pattern": "^sha256:(?!0{64})[0-9a-f]{64}$"},
    "raw_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "stack_arn": {
      "type": "string",
      "pattern": "^arn:aws:cloudformation:us-east-1:042360977644:stack/scanalyze-platform-authority-lambda-audit-repair-pep/[0-9a-fA-F-]{36}$"
    },
    "change_set_arn": {
      "type": "string",
      "pattern": "^arn:aws:cloudformation:us-east-1:042360977644:changeSet/gug221-lambda-audit-repair-pep-create/[0-9a-fA-F-]{36}$"
    },
    "client_token": {"type": "string", "pattern": "^gug221-b-[0-9a-f]{48}$"}
  }
}
