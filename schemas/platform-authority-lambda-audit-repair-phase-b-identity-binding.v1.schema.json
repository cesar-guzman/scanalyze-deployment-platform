{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-phase-b-identity-binding.v1.schema.json",
  "title": "GUG-221 Phase B Identity and Execution Binding v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "environment",
    "production",
    "authority_account_id",
    "management_account_id",
    "region",
    "identity_center_application_arn",
    "identity_center_instance_arn",
    "identity_store_arn",
    "redirect_uri",
    "operator_user_id",
    "invoker_role_arn",
    "broker_execution_role_arn",
    "proof_role_arn",
    "ledger_table_arn",
    "stack_arn",
    "change_set_arn",
    "change_set_name",
    "client_request_token",
    "phase_b_intent_digest",
    "change_set_receipt_digest",
    "template_digest",
    "parameters_digest",
    "resource_inventory_digest",
    "ledger_controls_digest",
    "oauth_state_digest",
    "invoker_policy_sha256",
    "broker_policy_sha256",
    "proof_policy_sha256",
    "application_actor_policy_sha256",
    "broker_artifact_code_sha256",
    "broker_code_signing_config_arn",
    "broker_alias_arn",
    "broker_topology_provider_evidence_digest",
    "broker_topology_signing_key_arn",
    "broker_topology_signature_algorithm",
    "provider_readback_required",
    "provider_readback_evidence_bound",
    "live_provider_state_verified_by_broker",
    "broker_topology_sha256",
    "execution_request_digest",
    "execution_id",
    "execution_not_before",
    "execution_not_after",
    "proof_duration_seconds",
    "max_token_lifetime_seconds",
    "identity_session_mode",
    "direct_identity_session_execute_change_set",
    "effect_principal_type",
    "native_on_behalf_of",
    "binding_digest"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "record_type": {"const": "platform_authority_lambda_audit_repair_phase_b_identity_binding"},
    "environment": {"const": "non-production"},
    "production": {"const": false},
    "authority_account_id": {"const": "042360977644"},
    "management_account_id": {"const": "839393571433"},
    "region": {"const": "us-east-1"},
    "identity_center_application_arn": {
      "type": "string",
      "pattern": "^arn:aws:sso::839393571433:application/ssoins-[A-Za-z0-9]{16}/apl-[A-Za-z0-9]{16}$"
    },
    "identity_center_instance_arn": {
      "type": "string",
      "pattern": "^arn:aws:sso:::instance/ssoins-[A-Za-z0-9]{16}$"
    },
    "identity_store_arn": {
      "type": "string",
      "pattern": "^arn:aws:identitystore::839393571433:identitystore/d-[a-z0-9]{10,}$"
    },
    "redirect_uri": {
      "type": "string",
      "pattern": "^http://127[.]0[.]0[.]1:[0-9]{4,5}/callback$"
    },
    "operator_user_id": {"$ref": "#/$defs/user_id"},
    "invoker_role_arn": {
      "type": "string",
      "pattern": "^arn:aws:iam::042360977644:role/aws-reserved/sso[.]amazonaws[.]com(?:/[a-z0-9-]+)?/AWSReservedSSO_ScanalyzeGug221PhaseBInvoker_[0-9A-Fa-f]{16}$"
    },
    "broker_execution_role_arn": {
      "const": "arn:aws:iam::042360977644:role/ScanalyzeGug221PhaseBBrokerExecution"
    },
    "proof_role_arn": {
      "const": "arn:aws:iam::042360977644:role/ScanalyzeGug221PhaseBProof"
    },
    "ledger_table_arn": {
      "const": "arn:aws:dynamodb:us-east-1:042360977644:table/scanalyze-platform-authority-gug221-phase-b-execution-ledger"
    },
    "stack_arn": {"$ref": "#/$defs/stack_arn"},
    "change_set_arn": {"$ref": "#/$defs/change_set_arn"},
    "change_set_name": {"const": "gug221-lambda-audit-repair-pep-create"},
    "client_request_token": {"$ref": "#/$defs/client_token"},
    "phase_b_intent_digest": {"$ref": "#/$defs/digest"},
    "change_set_receipt_digest": {"$ref": "#/$defs/digest"},
    "template_digest": {"$ref": "#/$defs/digest"},
    "parameters_digest": {"$ref": "#/$defs/digest"},
    "resource_inventory_digest": {"$ref": "#/$defs/digest"},
    "ledger_controls_digest": {"$ref": "#/$defs/digest"},
    "oauth_state_digest": {"$ref": "#/$defs/digest"},
    "invoker_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "broker_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "proof_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "application_actor_policy_sha256": {"$ref": "#/$defs/raw_digest"},
    "broker_artifact_code_sha256": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]{43}=$"
    },
    "broker_code_signing_config_arn": {
      "type": "string",
      "pattern": "^arn:aws:lambda:us-east-1:042360977644:code-signing-config:csc-[a-z0-9]{17}$"
    },
    "broker_alias_arn": {
      "const": "arn:aws:lambda:us-east-1:042360977644:function:scanalyze-platform-authority-gug221-phase-b-broker:broker-v1"
    },
    "broker_topology_provider_evidence_digest": {"$ref": "#/$defs/nonzero_digest"},
    "broker_topology_signing_key_arn": {
      "type": "string",
      "pattern": "^arn:aws:kms:us-east-1:042360977644:key/[0-9a-fA-F-]{36}$"
    },
    "broker_topology_signature_algorithm": {"const": "ECDSA_SHA_256"},
    "provider_readback_required": {"const": true},
    "provider_readback_evidence_bound": {"const": true},
    "live_provider_state_verified_by_broker": {"const": false},
    "broker_topology_sha256": {"$ref": "#/$defs/digest"},
    "execution_request_digest": {"$ref": "#/$defs/digest"},
    "execution_id": {
      "type": "string",
      "pattern": "^gug221-phase-b-[0-9a-f]{64}$"
    },
    "execution_not_before": {"$ref": "#/$defs/timestamp"},
    "execution_not_after": {"$ref": "#/$defs/timestamp"},
    "proof_duration_seconds": {"const": 900},
    "max_token_lifetime_seconds": {"const": 900},
    "identity_session_mode": {"const": "IDENTITY_ENHANCED_PROOF_ONLY"},
    "direct_identity_session_execute_change_set": {"const": false},
    "effect_principal_type": {"const": "AWS_SERVICE_ROLE"},
    "native_on_behalf_of": {"const": false},
    "binding_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nonzero_digest": {"type": "string", "pattern": "^sha256:(?!0{64})[0-9a-f]{64}$"},
    "raw_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "user_id": {
      "type": "string",
      "pattern": "^(?:[0-9a-fA-F]{10}-)?[0-9a-fA-F]{8}(?:-[0-9a-fA-F]{4}){3}-[0-9a-fA-F]{12}$"
    },
    "stack_arn": {
      "type": "string",
      "pattern": "^arn:aws:cloudformation:us-east-1:042360977644:stack/scanalyze-platform-authority-lambda-audit-repair-pep/[0-9a-fA-F-]{36}$"
    },
    "change_set_arn": {
      "type": "string",
      "pattern": "^arn:aws:cloudformation:us-east-1:042360977644:changeSet/gug221-lambda-audit-repair-pep-create/[0-9a-fA-F-]{36}$"
    },
    "client_token": {
      "type": "string",
      "pattern": "^gug221-b-[0-9a-f]{48}$"
    }
  }
}
