{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/platform-authority-lambda-audit-repair-phase-b-closure-pending-receipt.v1.schema.json",
  "title": "GUG-221 Phase B Provider Closure Pending Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "environment",
    "production",
    "status",
    "execution_id",
    "binding_digest",
    "ledger_digest",
    "broker_topology_sha256",
    "broker_topology_provider_evidence_digest",
    "execution_status",
    "issued_at",
    "revocation_scope",
    "execution_binding_consumed",
    "authority_revoked",
    "provider_revocation_verified",
    "identity_center_assignment_removed",
    "invoke_permission_removed",
    "pending_operations_absent",
    "extant_sessions_invalidated",
    "wall_clock_window_expired",
    "live_closure_status",
    "attempts",
    "retry_permitted",
    "native_on_behalf_of",
    "receipt_digest"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "record_type": {"const": "platform_authority_lambda_audit_repair_phase_b_closure_pending_receipt"},
    "environment": {"const": "non-production"},
    "production": {"const": false},
    "status": {"const": "PROVIDER_REVOCATION_PENDING"},
    "execution_id": {"type": "string", "pattern": "^gug221-phase-b-[0-9a-f]{64}$"},
    "binding_digest": {"$ref": "#/$defs/digest"},
    "ledger_digest": {"$ref": "#/$defs/digest"},
    "broker_topology_sha256": {"$ref": "#/$defs/digest"},
    "broker_topology_provider_evidence_digest": {"$ref": "#/$defs/nonzero_digest"},
    "execution_status": {"enum": ["DISPATCH_ACCEPTED", "UNCERTAIN_RECONCILE_ONLY"]},
    "issued_at": {"$ref": "#/$defs/timestamp"},
    "revocation_scope": {"const": "PROVIDER_IDENTITY_AND_INVOKE_AUTHORITY"},
    "execution_binding_consumed": {"const": true},
    "authority_revoked": {"const": false},
    "provider_revocation_verified": {"const": false},
    "identity_center_assignment_removed": {"const": false},
    "invoke_permission_removed": {"const": false},
    "pending_operations_absent": {"const": false},
    "extant_sessions_invalidated": {"const": false},
    "wall_clock_window_expired": {"const": false},
    "live_closure_status": {"const": "PENDING_PROVIDER_READBACK_AND_SESSION_EXPIRY"},
    "attempts": {"const": 1},
    "retry_permitted": {"const": false},
    "native_on_behalf_of": {"const": false},
    "receipt_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nonzero_digest": {"type": "string", "pattern": "^sha256:(?!0{64})[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "format": "date-time", "pattern": "Z$"}
  }
}
