{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/live-reconciliation-receipt.v1.schema.json",
  "title": "Scanalyze Uncertain Apply Reconciliation Receipt v1",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "customer_id",
    "deployment_id",
    "account_id",
    "region",
    "environment",
    "execution_id",
    "change_id",
    "layer",
    "plan_record_digest",
    "source_ledger_digest",
    "source_ledger_version",
    "observed_state_lineage_matches",
    "observed_state_serial",
    "speculative_plan_result",
    "contract_verified",
    "decision",
    "cloud_writes",
    "checked_at",
    "receipt_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "record_type": { "const": "live_reconciliation_receipt" },
    "customer_id": { "type": "string", "pattern": "^cust_[0-9A-HJKMNP-TV-Z]{26}$" },
    "deployment_id": { "type": "string", "pattern": "^dep_[0-9A-HJKMNP-TV-Z]{26}$" },
    "account_id": { "type": "string", "pattern": "^(?!000000000000$)[0-9]{12}$" },
    "region": { "type": "string", "pattern": "^[a-z]{2}(?:-[a-z]+)+-[0-9]+$" },
    "environment": { "enum": ["sandbox", "dev", "staging"] },
    "execution_id": { "type": "string", "pattern": "^exec_[0-9A-HJKMNP-TV-Z]{26}$" },
    "change_id": { "type": "string", "pattern": "^chg_[0-9A-HJKMNP-TV-Z]{26}$" },
    "layer": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "plan_record_digest": { "$ref": "#/$defs/digest" },
    "source_ledger_digest": { "$ref": "#/$defs/digest" },
    "source_ledger_version": { "type": "integer", "minimum": 1 },
    "observed_state_lineage_matches": { "type": "boolean" },
    "observed_state_serial": { "type": "integer", "minimum": 0 },
    "speculative_plan_result": { "enum": ["NO_CHANGE", "CHANGE", "ERROR"] },
    "contract_verified": { "type": "boolean" },
    "decision": { "enum": ["RECONCILED_APPLIED", "RECONCILIATION_REQUIRED"] },
    "cloud_writes": { "const": false },
    "checked_at": { "type": "string", "format": "date-time" },
    "receipt_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
