    },
    "stack_arn": {
      "$ref": "#/$defs/stack_arn"
    },
    "client_request_token": {
      "type": "string",
      "pattern": "^gug221-b-[0-9a-f]{48}$"
    },
    "client_request_token_sha256": {
      "$ref": "#/$defs/digest"
    },
    "execute_request_sha256": {
      "$ref": "#/$defs/digest"
    },
    "effect_principal_arn_sha256": {
      "$ref": "#/$defs/digest"
    },
    "execute_event": {
