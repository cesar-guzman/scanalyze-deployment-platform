      "properties": {
        "event_id": {
          "$ref": "#/$defs/uuid"
        },
        "event_time": {
          "$ref": "#/$defs/timestamp"
        },
        "event_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "sanitized_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_time",
        "physical_resource_id_sha256"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_time": {
          "$ref": "#/$defs/timestamp"
        },
        "physical_resource_id_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "complete_event": {
      "allOf": [
        {
          "$ref": "#/$defs/sanitized_event"
        },
        {
          "properties": {
            "physical_resource_id_sha256": {
              "$ref": "#/$defs/digest"
            }
          }
        }
      ]
    },
    "stack_event_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_resource_id",
        "resource_type",
        "client_request_token_sha256",
        "in_progress_events",
        "complete_event"
      ],
      "properties": {
        "logical_resource_id": {
          "type": "string",
          "minLength": 1
        },
        "resource_type": {
          "type": "string",
          "pattern": "^AWS::"
        },
        "client_request_token_sha256": {
          "$ref": "#/$defs/digest"
        },
        "in_progress_events": {
          "type": "array",
          "minItems": 1,
          "maxItems": 217,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/sanitized_event"
          }
        },
        "complete_event": {
          "$ref": "#/$defs/complete_event"
        }
      }
    },
    "output_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_key",
        "output_value_sha256"
      ],
      "properties": {
        "output_key": {
          "type": "string",
          "minLength": 1
        },
        "output_value_sha256": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "resource_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_resource_id",
        "resource_type",
        "physical_resource_id_sha256"
      ],
      "properties": {
        "logical_resource_id": {
          "type": "string",
          "minLength": 1
        },
        "resource_type": {
          "type": "string",
          "pattern": "^AWS::"
        },
        "physical_resource_id_sha256": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "terminal_resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_time",
        "logical_resource_id",
        "resource_type",
        "resource_status",
        "physical_resource_id_sha256"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_time": {
          "$ref": "#/$defs/timestamp"
        },
        "logical_resource_id": {
          "type": "string",
          "minLength": 1
        },
        "resource_type": {
          "type": "string",
          "pattern": "^AWS::"
        },
        "resource_status": {
          "const": "CREATE_COMPLETE"
        },
        "physical_resource_id_sha256": {
          "$ref": "#/$defs/digest"
        }
      }
    },
