    },
    "pep_change_set_receipt_sha256": {
      "$ref": "#/$defs/digest"
    },
    "phase_b_precondition_parameter_handoff_sha256": {
      "$ref": "#/$defs/digest"
    },
    "phase_b_precondition_change_set_receipt_sha256": {
      "$ref": "#/$defs/digest"
    },
    "broker_effect_receipt_sha256": {
