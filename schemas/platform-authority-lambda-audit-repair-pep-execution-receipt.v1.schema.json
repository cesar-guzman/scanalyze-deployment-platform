  "$defs": {
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "prefixed_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "broker_ledger_provider_readback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "table_name_sha256",
        "execution_id_sha256",
        "binding_digest",
        "proof_receipt_digest",
        "ledger_digest",
        "closure_pending_receipt_digest",
        "execution_request_digest",
        "broker_topology_sha256",
        "broker_topology_provider_evidence_digest",
        "status",
        "attempts",
        "execution_gate_consumed",
        "execution_ambiguous",
        "retry_permitted",
        "native_on_behalf_of",
        "closure_status"
      ],
      "properties": {
        "table_name_sha256": {"$ref": "#/$defs/digest"},
        "execution_id_sha256": {"$ref": "#/$defs/digest"},
        "binding_digest": {"$ref": "#/$defs/prefixed_digest"},
        "proof_receipt_digest": {"$ref": "#/$defs/prefixed_digest"},
        "ledger_digest": {"$ref": "#/$defs/prefixed_digest"},
        "closure_pending_receipt_digest": {
          "$ref": "#/$defs/prefixed_digest"
        },
        "execution_request_digest": {
          "$ref": "#/$defs/prefixed_digest"
        },
        "broker_topology_sha256": {"$ref": "#/$defs/prefixed_digest"},
        "broker_topology_provider_evidence_digest": {
          "$ref": "#/$defs/prefixed_digest"
        },
        "status": {"const": "DISPATCH_ACCEPTED"},
        "attempts": {"const": 1},
        "execution_gate_consumed": {"const": true},
        "execution_ambiguous": {"const": false},
        "retry_permitted": {"const": false},
        "native_on_behalf_of": {"const": false},
        "closure_status": {"const": "PROVIDER_REVOCATION_PENDING"}
      }
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "change_set_arn": {
      "type": "string",
      "pattern": "^arn:aws:cloudformation:us-east-1:042360977644:changeSet/gug221-lambda-audit-repair-pep-create/[0-9a-fA-F-]{36}$"
    },
    "stack_arn": {
      "type": "string",
      "pattern": "^arn:aws:cloudformation:us-east-1:042360977644:stack/scanalyze-platform-authority-lambda-audit-repair-pep/[0-9a-fA-F-]{36}$"
    },
    "provider_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_time",
        "event_digest"
