    "stack_events": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stack_event_transition"
      }
    },
    "stack_events_sha256": {
      "$ref": "#/$defs/digest"
    },
    "terminal_resources": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "uniqueItems": true,
      "prefixItems": [
