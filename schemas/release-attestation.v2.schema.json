{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scanalyze.dev/schemas/release-attestation.v2.schema.json",
  "title": "Scanalyze Signed Release Policy Attestation v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "statement", "signature"],
  "properties": {
    "schema_version": { "const": "release-attestation.v2" },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["_type", "subject", "predicateType", "predicate"],
      "properties": {
        "_type": { "const": "https://in-toto.io/Statement/v1" },
        "subject": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "digest"],
            "properties": {
              "name": { "const": "scanalyze-release-manifest" },
              "digest": {
                "type": "object",
                "additionalProperties": false,
                "required": ["sha256"],
                "properties": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
              }
            }
          }
        },
        "predicateType": { "const": "https://slsa.dev/verification_summary/v1" },
        "predicate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "verifier",
            "timeVerified",
            "resourceUri",
            "policy",
            "inputAttestations",
            "verificationResult",
            "verifiedLevels",
            "artifactSubjects"
          ],
          "properties": {
            "verifier": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "version", "digest"],
              "properties": {
                "id": { "type": "string", "format": "uri" },
                "version": { "type": "string", "pattern": "^[0-9]+[.][0-9]+[.][0-9]+$" },
                "digest": { "$ref": "#/$defs/sha256" }
              }
            },
            "timeVerified": { "type": "string", "format": "date-time" },
            "resourceUri": { "const": "pkg:generic/scanalyze/release-manifest" },
            "policy": {
              "type": "object",
              "additionalProperties": false,
              "required": ["uri", "digest"],
              "properties": {
                "uri": { "const": "https://scanalyze.dev/policies/supply-chain/release-policy/v1" },
                "digest": { "$ref": "#/$defs/sha256" }
              }
            },
            "inputAttestations": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/sha256" },
              "uniqueItems": true
            },
            "verificationResult": { "const": "PASSED" },
            "verifiedLevels": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "enum": ["SLSA_BUILD_LEVEL_1", "SLSA_BUILD_LEVEL_2", "SLSA_BUILD_LEVEL_3"] },
              "uniqueItems": true
            },
            "artifactSubjects": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "issuer", "identity", "value"],
      "properties": {
        "algorithm": { "const": "ECDSA_P256_SHA256" },
        "key_id": { "type": "string", "pattern": "^[A-Za-z0-9._:/-]{1,256}$" },
        "issuer": { "type": "string", "format": "uri" },
        "identity": { "type": "string", "format": "uri" },
        "value": { "type": "string", "pattern": "^[A-Za-z0-9+/]+={0,2}$", "maxLength": 256 }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
