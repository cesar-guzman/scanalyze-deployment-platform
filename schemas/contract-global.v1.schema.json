{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scanalyze.contract.global.v1",
  "title": "Global Layer Contract Outputs",
  "type": "object",
  "required": ["ecs_execution_role_arn", "ecs_task_role_arns"],
  "additionalProperties": false,
  "properties": {
    "ecs_execution_role_arn": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$" },
    "ecs_task_role_arns": {
      "type": "object",
      "description": "Per-service task role ARNs",
      "additionalProperties": false,
      "properties": {
        "scanalyze-ingest-api": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$" },
        "scanalyze-ocr-worker": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$" },
        "scanalyze-classifier-worker": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$" },
        "scanalyze-bank-worker": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$" },
        "scanalyze-personal-worker": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$" },
        "scanalyze-gov-worker": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$" },
        "scanalyze-postprocess-worker": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:role/.+$" }
      }
    },
    "permissions_boundary_arn": { "type": "string", "pattern": "^arn:aws:iam::[0-9]{12}:policy/.+$" }
  }
}
