{
  "schema_version": "1",
  "contracts": {
    "account-ready/v1": {
      "authority": "account-baseline",
      "producer": null,
      "output_schema": "schemas/account-ready.v1.schema.json",
      "scope": "external",
      "transport": { "kind": "deployment-record" },
      "consumers": ["account-ready-gate", "global"],
      "consumer_bindings": {
        "account-ready-gate": {},
        "global": {}
      }
    },
    "global/v1": {
      "authority": "terraform-root",
      "producer": "global",
      "output_schema": "schemas/contract-global.v1.schema.json",
      "scope": "global",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/global/v1/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["network", "identity-control-plane", "services"],
      "consumer_bindings": {
        "network": {
          "metadata_variables": {
            "contract_digest": ["upstream_contract_digest", "expected_upstream_digest"],
            "output_schema_major": ["upstream_schema_version"]
          }
        },
        "identity-control-plane": {
          "contract_variable": "global_contract",
          "metadata_variables": {
            "contract_digest": ["expected_global_contract_digest"]
          }
        },
        "services": {
          "output_variables": {
            "ecs_execution_role_arn": "ecs_task_execution_role_arn",
            "ecs_task_role_arns": "workload_role_arns"
          }
        }
      }
    },
    "network/v2": {
      "authority": "terraform-root",
      "producer": "network",
      "output_schema": "schemas/contract-network.v2.schema.json",
      "scope": "regional",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/network/v2/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["platform", "services", "edge-identity"],
      "consumer_bindings": {
        "platform": {
          "output_variables": {
            "vpc_id": "vpc_id",
            "private_subnet_ids": "private_subnet_ids",
            "vpc_cidr_block": "vpc_cidr_block"
          },
          "metadata_variables": {
            "contract_digest": ["upstream_contract_digest", "expected_upstream_digest"],
            "output_schema_major": ["upstream_schema_version"]
          }
        },
        "services": {
          "output_variables": {
            "vpc_id": "vpc_id",
            "private_subnet_ids": "private_subnet_ids"
          }
        },
        "edge-identity": {
          "contract_variable": "network_contract",
          "metadata_variables": {
            "contract_digest": ["expected_network_contract_digest"]
          }
        }
      }
    },
    "platform/v2": {
      "authority": "terraform-root",
      "producer": "platform",
      "output_schema": "schemas/contract-platform.v2.schema.json",
      "scope": "regional",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/platform/v2/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["data-foundation", "cicd", "services", "edge-identity"],
      "consumer_bindings": {
        "data-foundation": {
          "metadata_variables": {
            "contract_digest": ["upstream_contract_digest", "expected_upstream_digest"],
            "output_schema_major": ["upstream_schema_version"]
          }
        },
        "cicd": {
          "output_variables": { "ecs_cluster_name": "ecs_cluster_name" }
        },
        "services": {
          "output_variables": {
            "ecs_cluster_arn": "ecs_cluster_arn",
            "alb_listener_arn": "alb_listener_arn",
            "alb_security_group_id": "alb_security_group_id"
          }
        },
        "edge-identity": {
          "contract_variable": "platform_contract",
          "metadata_variables": {
            "contract_digest": ["expected_platform_contract_digest"]
          }
        }
      }
    },
    "data-foundation/v2": {
      "authority": "terraform-root",
      "producer": "data-foundation",
      "output_schema": "schemas/contract-data-foundation.v2.schema.json",
      "scope": "regional",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/data-foundation/v2/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["cicd", "services"],
      "consumer_bindings": {
        "cicd": {
          "metadata_variables": {
            "contract_digest": ["upstream_contract_digest", "expected_upstream_digest"],
            "output_schema_version": ["upstream_contract_id"],
            "output_schema_major": ["upstream_schema_version"]
          }
        },
        "services": {
          "metadata_variables": {
            "contract_digest": ["upstream_contract_digest", "expected_upstream_digest"],
            "output_schema_version": ["upstream_contract_id"],
            "output_schema_major": ["upstream_schema_version"]
          }
        }
      }
    },
    "cicd/v2": {
      "authority": "terraform-root",
      "producer": "cicd",
      "output_schema": "schemas/cicd-contract.v2.schema.json",
      "scope": "regional",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/cicd/v2/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["artifact-publication", "services"],
      "consumer_bindings": {
        "artifact-publication": {},
        "services": {}
      }
    },
    "release-manifest/v1": {
      "authority": "release",
      "producer": "artifact-publication",
      "output_schema": "schemas/release-manifest.schema.json",
      "scope": "external",
      "transport": { "kind": "release-artifact" },
      "consumers": ["identity-control-plane", "services", "synthetic-validation"],
      "consumer_bindings": {
        "identity-control-plane": { "contract_variable": "release_manifest_contract" },
        "services": {},
        "synthetic-validation": {}
      }
    },
    "identity-contract/v2": {
      "authority": "identity-registry",
      "producer": null,
      "output_schema": "schemas/identity-contract.v2.schema.json",
      "scope": "external",
      "transport": { "kind": "deployment-record" },
      "consumers": ["identity-control-plane"],
      "consumer_bindings": {
        "identity-control-plane": { "contract_variable": "m2m_registry_contract" }
      }
    },
    "identity-control-plane/v1": {
      "authority": "terraform-root",
      "producer": "identity-control-plane",
      "output_schema": "schemas/contract-identity-control-plane.v1.schema.json",
      "scope": "regional",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/identity-control-plane/v1/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["services", "edge-identity", "synthetic-validation"],
      "consumer_bindings": {
        "services": {
          "contract_variable": "identity_control_plane_contract",
          "metadata_variables": {
            "contract_digest": ["expected_identity_control_plane_contract_digest"]
          }
        },
        "edge-identity": {
          "contract_variable": "identity_contract",
          "metadata_variables": {
            "contract_digest": ["expected_identity_contract_digest"]
          }
        },
        "synthetic-validation": {}
      }
    },
    "services/v2": {
      "authority": "terraform-root",
      "producer": "services",
      "output_schema": "schemas/contract-services.v2.schema.json",
      "scope": "regional",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/services/v2/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["edge-identity", "synthetic-validation"],
      "consumer_bindings": {
        "edge-identity": {
          "contract_variable": "services_contract",
          "metadata_variables": {
            "contract_digest": ["expected_services_contract_digest"]
          }
        },
        "synthetic-validation": {}
      }
    },
    "edge-identity/v2": {
      "authority": "terraform-root",
      "producer": "edge-identity",
      "output_schema": "schemas/contract-edge-identity.v2.schema.json",
      "scope": "regional",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/edge-identity/v2/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["edge", "synthetic-validation"],
      "consumer_bindings": {
        "edge": {
          "output_variables": { "api_gateway_endpoint": "api_gateway_endpoint" },
          "metadata_variables": {
            "contract_digest": ["upstream_contract_digest", "expected_upstream_digest"],
            "output_schema_version": ["upstream_contract_id"],
            "output_schema_major": ["upstream_schema_version"]
          }
        },
        "synthetic-validation": {}
      }
    },
    "edge/v2": {
      "authority": "terraform-root",
      "producer": "edge",
      "output_schema": "schemas/contract-edge.v2.schema.json",
      "scope": "global",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/edge/v2/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["addons", "synthetic-validation"],
      "consumer_bindings": {
        "addons": {
          "metadata_variables": {
            "contract_digest": ["upstream_contract_digest", "expected_upstream_digest"],
            "output_schema_major": ["upstream_schema_version"]
          }
        },
        "synthetic-validation": {}
      }
    },
    "addons/v2": {
      "authority": "terraform-root",
      "producer": "addons",
      "output_schema": "schemas/contract-addons.v2.schema.json",
      "scope": "regional",
      "transport": {
        "kind": "ssm",
        "path_template": "/scanalyze/deployments/{deployment_id}/contracts/addons/v2/releases/{release_digest}/digests/{contract_digest}"
      },
      "consumers": ["synthetic-validation"],
      "consumer_bindings": { "synthetic-validation": {} }
    }
  }
}
