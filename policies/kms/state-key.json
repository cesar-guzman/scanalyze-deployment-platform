{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowKeyAdminByBaseline",
      "Effect": "Allow",
      "Action": [
        "kms:Create*",
        "kms:Describe*",
        "kms:Enable*",
        "kms:List*",
        "kms:Put*",
        "kms:Update*",
        "kms:Revoke*",
        "kms:Disable*",
        "kms:Get*",
        "kms:Delete*",
        "kms:ScheduleKeyDeletion",
        "kms:CancelKeyDeletion"
      ],
      "Resource": "*",
      "Principal": {
        "AWS": "arn:aws:iam::${account_id}:root"
      }
    },
    {
      "Sid": "AllowPlanDecrypt",
      "Effect": "Allow",
      "Action": ["kms:Decrypt"],
      "Resource": "*",
      "Principal": {
        "AWS": "arn:aws:iam::${account_id}:role/ScanalyzeCustomer-Plan"
      }
    },
    {
      "Sid": "AllowApplyFullCrypto",
      "Effect": "Allow",
      "Action": ["kms:Encrypt", "kms:Decrypt", "kms:GenerateDataKey"],
      "Resource": "*",
      "Principal": {
        "AWS": "arn:aws:iam::${account_id}:role/ScanalyzeCustomer-Apply"
      }
    },
    {
      "Sid": "AllowDiagnosticDecrypt",
      "Effect": "Allow",
      "Action": ["kms:Decrypt"],
      "Resource": "*",
      "Principal": {
        "AWS": "arn:aws:iam::${account_id}:role/ScanalyzeCustomer-Diagnostic"
      }
    },
    {
      "Sid": "AllowStateRecoveryFullCrypto",
      "Effect": "Allow",
      "Action": ["kms:Encrypt", "kms:Decrypt", "kms:GenerateDataKey"],
      "Resource": "*",
      "Principal": {
        "AWS": "arn:aws:iam::${account_id}:role/ScanalyzeCustomer-StateRecovery"
      }
    }
  ]
}
