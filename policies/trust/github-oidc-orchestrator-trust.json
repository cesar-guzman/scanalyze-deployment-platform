{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowExactGitHubDeploymentIdentity",
      "Effect": "Allow",
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Principal": {
        "Federated": "arn:aws:iam::${shared_services_account_id}:oidc-provider/token.actions.githubusercontent.com"
      },
      "Condition": {
        "StringEquals": {
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
          "token.actions.githubusercontent.com:sub": "${github_oidc_subject}"
        }
      }
    }
  ]
}
