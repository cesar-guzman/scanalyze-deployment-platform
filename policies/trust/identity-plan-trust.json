{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowOrchestratorAssumeIdentityPlan",
      "Effect": "Allow",
      "Action": "sts:AssumeRole",
      "Principal": {
        "AWS": "arn:aws:iam::${shared_services_account_id}:role/ScanalyzeOrchestrator-${deployment_id}"
      },
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/customer_id": "${aws:ResourceTag/customer_id}",
          "aws:RequestTag/deployment_id": "${aws:ResourceTag/deployment_id}",
          "aws:RequestTag/account_id": "${aws:ResourceTag/account_id}",
          "aws:RequestTag/region": "${aws:ResourceTag/region}",
          "aws:RequestTag/environment": "${aws:ResourceTag/environment}",
          "aws:RequestTag/operation": "plan",
          "aws:RequestTag/layer": "identity-control-plane"
        },
        "StringLike": {
          "aws:RequestTag/change_id": "chg_*",
          "sts:SourceIdentity": "exec_*"
        }
      }
    },
    {
      "Sid": "AllowOrchestratorTagIdentityPlanSession",
      "Effect": "Allow",
      "Action": "sts:TagSession",
      "Principal": {
        "AWS": "arn:aws:iam::${shared_services_account_id}:role/ScanalyzeOrchestrator-${deployment_id}"
      },
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/customer_id": "${aws:ResourceTag/customer_id}",
          "aws:RequestTag/deployment_id": "${aws:ResourceTag/deployment_id}",
          "aws:RequestTag/account_id": "${aws:ResourceTag/account_id}",
          "aws:RequestTag/region": "${aws:ResourceTag/region}",
          "aws:RequestTag/environment": "${aws:ResourceTag/environment}",
          "aws:RequestTag/operation": "plan",
          "aws:RequestTag/layer": "identity-control-plane"
        },
        "StringLike": {
          "aws:RequestTag/change_id": "chg_*"
        },
        "ForAllValues:StringEquals": {
          "aws:TagKeys": [
            "customer_id",
            "deployment_id",
            "account_id",
            "region",
            "environment",
            "operation",
            "layer",
            "change_id"
          ]
        },
        "Null": {
          "aws:TagKeys": "false",
          "aws:RequestTag/customer_id": "false",
          "aws:RequestTag/deployment_id": "false",
          "aws:RequestTag/account_id": "false",
          "aws:RequestTag/region": "false",
          "aws:RequestTag/environment": "false",
          "aws:RequestTag/operation": "false",
          "aws:RequestTag/layer": "false",
          "aws:RequestTag/change_id": "false"
        }
      }
    },
    {
      "Sid": "AllowOrchestratorSetIdentityPlanSourceIdentity",
      "Effect": "Allow",
      "Action": "sts:SetSourceIdentity",
      "Principal": {
        "AWS": "arn:aws:iam::${shared_services_account_id}:role/ScanalyzeOrchestrator-${deployment_id}"
      },
      "Condition": {
        "StringLike": {
          "sts:SourceIdentity": "exec_*"
        }
      }
    }
  ]
}
