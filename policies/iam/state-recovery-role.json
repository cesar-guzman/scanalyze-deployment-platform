{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadState",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::scanalyze-${account_id}-tf-state",
        "arn:aws:s3:::scanalyze-${account_id}-tf-state/${deployment_id}/*"
      ]
    },
    {
      "Sid": "WriteStateForRecovery",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-tf-state/${deployment_id}/*",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/operation": "state-recovery"
        }
      }
    },
    {
      "Sid": "EncryptDecryptStateKey",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "arn:aws:kms:${region}:${account_id}:key/${state_kms_key_id}"
    },
    {
      "Sid": "DenyNonStateAccess",
      "Effect": "Deny",
      "Action": [
        "ec2:*",
        "ecs:*",
        "dynamodb:*",
        "sqs:*",
        "ssm:PutParameter",
        "iam:*",
        "ecr:*"
      ],
      "Resource": "*"
    }
  ]
}
