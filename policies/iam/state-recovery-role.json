{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListBoundStateVersions",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-tf-state",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["${deployment_id}/*/terraform.tfstate"]
        },
        "StringEquals": {
          "aws:PrincipalTag/deployment_id": "${deployment_id}",
          "aws:PrincipalTag/operation": "state-recovery"
        }
      }
    },
    {
      "Sid": "ReadBoundStateVersions",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion"
      ],
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-tf-state/${deployment_id}/*/terraform.tfstate",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalTag/deployment_id": "${deployment_id}",
          "aws:PrincipalTag/operation": "state-recovery"
        }
      }
    },
    {
      "Sid": "RestoreBoundStateVersion",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-tf-state/${deployment_id}/*/terraform.tfstate",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalTag/deployment_id": "${deployment_id}",
          "aws:PrincipalTag/operation": "state-recovery",
          "s3:x-amz-server-side-encryption": "aws:kms",
          "s3:x-amz-server-side-encryption-aws-kms-key-id": "arn:aws:kms:${region}:${account_id}:key/${state_kms_key_id}"
        }
      }
    },
    {
      "Sid": "DeleteOnlyReviewedNativeLockfile",
      "Effect": "Allow",
      "Action": "s3:DeleteObject",
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-tf-state/${deployment_id}/*/terraform.tfstate.tflock",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalTag/deployment_id": "${deployment_id}",
          "aws:PrincipalTag/operation": "state-recovery",
          "aws:PrincipalTag/recovery_approved": "true"
        }
      }
    },
    {
      "Sid": "EncryptDecryptStateKey",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "arn:aws:kms:${region}:${account_id}:key/${state_kms_key_id}"
    },
    {
      "Sid": "DenyNonStateAccess",
      "Effect": "Deny",
      "Action": [
        "ec2:*",
        "ecs:*",
        "dynamodb:*",
        "sqs:*",
        "ssm:PutParameter",
        "iam:*",
        "ecr:*"
      ],
      "Resource": "*"
    }
  ]
}
