{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadDeploymentRegistry",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:Query"
      ],
      "Resource": "arn:${aws_partition}:dynamodb:${region}:${shared_services_account_id}:table/scanalyze-deployment-registry",
      "Condition": {
        "ForAllValues:StringEquals": {
          "dynamodb:LeadingKeys": ["${aws:PrincipalTag/deployment_id}"]
        }
      }
    },
    {
      "Sid": "WriteDeploymentRegistry",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": "arn:${aws_partition}:dynamodb:${region}:${shared_services_account_id}:table/scanalyze-deployment-registry",
      "Condition": {
        "ForAllValues:StringEquals": {
          "dynamodb:LeadingKeys": ["${aws:PrincipalTag/deployment_id}"],
          "dynamodb:Attributes": [
            "schema_version",
            "record_type",
            "deployment_id",
            "customer_id",
            "account_id",
            "region",
            "environment",
            "status",
            "registry_version",
            "account_ready",
            "state_binding",
            "record_digest",
            "execution_lock",
            "release_version",
            "last_updated",
            "change_id",
            "wave_status"
          ]
        }
      }
    },
    {
      "Sid": "AssumeBoundCustomerRoles",
      "Effect": "Allow",
      "Action": "sts:AssumeRole",
      "Resource": [
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Plan",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Apply",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Identity-Plan",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Identity-Apply",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Promotion",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Validation"
      ],
      "Condition": {
        "StringEquals": {
          "aws:PrincipalTag/service": "scanalyze-orchestrator",
          "aws:RequestTag/customer_id": "${aws:PrincipalTag/customer_id}",
          "aws:RequestTag/deployment_id": "${aws:PrincipalTag/deployment_id}",
          "aws:RequestTag/account_id": "${aws:PrincipalTag/account_id}",
          "aws:RequestTag/region": "${aws:PrincipalTag/region}",
          "aws:RequestTag/environment": "${aws:PrincipalTag/environment}"
        },
        "StringLike": {
          "aws:RequestTag/change_id": "chg_*",
          "aws:RequestTag/operation": [
            "plan",
            "apply",
            "promote",
            "validate"
          ],
          "aws:RequestTag/layer": [
            "global",
            "network",
            "platform",
            "data-foundation",
            "cicd",
            "identity-control-plane",
            "services",
            "edge-identity",
            "edge",
            "addons",
            "artifact-publication",
            "synthetic-validation"
          ],
          "sts:SourceIdentity": "exec_*"
        }
      }
    },
    {
      "Sid": "TagBoundCustomerRoleSessions",
      "Effect": "Allow",
      "Action": "sts:TagSession",
      "Resource": [
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Plan",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Apply",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Identity-Plan",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Identity-Apply",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Promotion",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Validation"
      ],
      "Condition": {
        "StringEquals": {
          "aws:PrincipalTag/service": "scanalyze-orchestrator",
          "aws:RequestTag/customer_id": "${aws:PrincipalTag/customer_id}",
          "aws:RequestTag/deployment_id": "${aws:PrincipalTag/deployment_id}",
          "aws:RequestTag/account_id": "${aws:PrincipalTag/account_id}",
          "aws:RequestTag/region": "${aws:PrincipalTag/region}",
          "aws:RequestTag/environment": "${aws:PrincipalTag/environment}"
        },
        "StringLike": {
          "aws:RequestTag/change_id": "chg_*",
          "aws:RequestTag/operation": [
            "plan",
            "apply",
            "promote",
            "validate"
          ],
          "aws:RequestTag/layer": [
            "global",
            "network",
            "platform",
            "data-foundation",
            "cicd",
            "identity-control-plane",
            "services",
            "edge-identity",
            "edge",
            "addons",
            "artifact-publication",
            "synthetic-validation"
          ]
        },
        "ForAllValues:StringEquals": {
          "aws:TagKeys": [
            "customer_id",
            "deployment_id",
            "account_id",
            "region",
            "environment",
            "operation",
            "layer",
            "change_id"
          ]
        },
        "Null": {
          "aws:TagKeys": "false",
          "aws:RequestTag/customer_id": "false",
          "aws:RequestTag/deployment_id": "false",
          "aws:RequestTag/account_id": "false",
          "aws:RequestTag/region": "false",
          "aws:RequestTag/environment": "false",
          "aws:RequestTag/operation": "false",
          "aws:RequestTag/layer": "false",
          "aws:RequestTag/change_id": "false"
        }
      }
    },
    {
      "Sid": "SetBoundCustomerRoleSourceIdentity",
      "Effect": "Allow",
      "Action": "sts:SetSourceIdentity",
      "Resource": [
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Plan",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Apply",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Identity-Plan",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Identity-Apply",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Promotion",
        "arn:${aws_partition}:iam::${aws:PrincipalTag/account_id}:role/ScanalyzeCustomer-Validation"
      ],
      "Condition": {
        "StringEquals": {
          "aws:PrincipalTag/service": "scanalyze-orchestrator"
        },
        "StringLike": {
          "sts:SourceIdentity": "exec_*"
        }
      }
    },
    {
      "Sid": "ManageExecutionLedger",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": "arn:${aws_partition}:dynamodb:${region}:${shared_services_account_id}:table/scanalyze-deployment-executions",
      "Condition": {
        "ForAllValues:StringEquals": {
          "dynamodb:LeadingKeys": ["${aws:PrincipalTag/deployment_id}"],
          "dynamodb:Attributes": [
            "deployment_id",
            "record_key",
            "ledger_version",
            "ledger_digest",
            "status",
            "document"
          ]
        }
      }
    },
    {
      "Sid": "ReadReleaseManifests",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:${aws_partition}:s3:::${release_bucket_name}/*"
    },
    {
      "Sid": "DecryptReleaseManifests",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:DescribeKey"
      ],
      "Resource": "${platform_authority_kms_key_arn}",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "s3.${region}.${aws_dns_suffix}",
          "kms:EncryptionContext:aws:s3:arn": "arn:${aws_partition}:s3:::${release_bucket_name}"
        }
      }
    },
    {
      "Sid": "DenyEscalation",
      "Effect": "Deny",
      "Action": [
        "iam:CreateUser",
        "iam:CreateAccessKey",
        "iam:CreateRole",
        "iam:AttachRolePolicy",
        "iam:PutRolePolicy",
        "organizations:*"
      ],
      "Resource": "*"
    }
  ]
}
