{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadWriteTerraformState",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-tf-state/${deployment_id}/*/terraform.tfstate"
    },
    {
      "Sid": "ManageTerraformLock",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-tf-state/${deployment_id}/*/terraform.tfstate.tflock"
    },
    {
      "Sid": "ReadPlanExecutionZone",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-tf-evidence/plan-execution/${deployment_id}/*"
    },
    {
      "Sid": "WriteEvidence",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::scanalyze-${account_id}-tf-evidence/evidence/${deployment_id}/*",
        "arn:aws:s3:::scanalyze-${account_id}-tf-evidence/recovery/${deployment_id}/*"
      ]
    },
    {
      "Sid": "ReadWriteContracts",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath",
        "ssm:PutParameter"
      ],
      "Resource": "arn:aws:ssm:${region}:${account_id}:parameter/scanalyze/deployments/${deployment_id}/contracts/*"
    },
    {
      "Sid": "ReadWriteContractPayloads",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-contracts/${deployment_id}/*"
    },
    {
      "Sid": "ManageInfrastructure",
      "Effect": "Allow",
      "Action": [
        "ec2:*",
        "ecs:*",
        "elasticloadbalancing:*",
        "dynamodb:*",
        "s3:*",
        "sqs:*",
        "kms:*",
        "iam:*",
        "logs:*",
        "cloudwatch:*",
        "route53:*",
        "cloudfront:*",
        "wafv2:*",
        "cognito-idp:*",
        "apigateway:*",
        "lambda:*",
        "sns:*",
        "acm:*",
        "application-autoscaling:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalTag/deployment_id": "${deployment_id}"
        }
      }
    },
    {
      "Sid": "EncryptDecryptStateKey",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "arn:aws:kms:${region}:${account_id}:key/${state_kms_key_id}"
    },
    {
      "Sid": "EncryptEvidenceKey",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "arn:aws:kms:${region}:${account_id}:key/${evidence_kms_key_id}"
    },
    {
      "Sid": "EncryptDecryptContractsKey",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "arn:aws:kms:${region}:${account_id}:key/${contracts_kms_key_id}"
    },
    {
      "Sid": "DenyIAMUserCreation",
      "Effect": "Deny",
      "Action": [
        "iam:CreateUser",
        "iam:CreateAccessKey"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyOrganizations",
      "Effect": "Deny",
      "Action": [
        "organizations:*"
      ],
      "Resource": "*"
    }
  ]
}
