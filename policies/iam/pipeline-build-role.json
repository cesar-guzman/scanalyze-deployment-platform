{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PullBaseImages",
      "Effect": "Allow",
      "Action": [
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage",
        "ecr:BatchCheckLayerAvailability",
        "ecr:GetAuthorizationToken"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PushBuildArtifacts",
      "Effect": "Allow",
      "Action": [
        "ecr:PutImage",
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:BatchCheckLayerAvailability"
      ],
      "Resource": "arn:aws:ecr:${region}:${shared_services_account_id}:repository/scanalyze/*"
    },
    {
      "Sid": "ReadBuildSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": "arn:aws:secretsmanager:${region}:${shared_services_account_id}:secret:scanalyze/build/*"
    },
    {
      "Sid": "WriteBuildLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:${region}:${shared_services_account_id}:log-group:/scanalyze/build:*"
    },
    {
      "Sid": "ReadCodeArtifact",
      "Effect": "Allow",
      "Action": [
        "codeartifact:GetAuthorizationToken",
        "codeartifact:ReadFromRepository"
      ],
      "Resource": "arn:aws:codeartifact:${region}:${shared_services_account_id}:repository/scanalyze/*"
    },
    {
      "Sid": "DenyEscalation",
      "Effect": "Deny",
      "Action": [
        "iam:CreateUser",
        "iam:CreateAccessKey",
        "iam:CreateRole",
        "iam:AttachRolePolicy",
        "organizations:*"
      ],
      "Resource": "*"
    }
  ]
}
