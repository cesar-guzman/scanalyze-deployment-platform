{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudFrontOAC",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::scanalyze-${account_id}-frontend/${deployment_id}/*",
      "Principal": {
        "Service": "cloudfront.amazonaws.com"
      },
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "arn:aws:cloudfront::${account_id}:distribution/${cloudfront_distribution_id}"
        }
      }
    },
    {
      "Sid": "AllowPromotionWriteFrontend",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::scanalyze-${account_id}-frontend",
        "arn:aws:s3:::scanalyze-${account_id}-frontend/${deployment_id}/releases/*"
      ],
      "Principal": {
        "AWS": "arn:aws:iam::${account_id}:role/ScanalyzeCustomer-Promotion"
      }
    },
    {
      "Sid": "DenyNonTLS",
      "Effect": "Deny",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::scanalyze-${account_id}-frontend",
        "arn:aws:s3:::scanalyze-${account_id}-frontend/*"
      ],
      "Principal": "*",
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    },
    {
      "Sid": "DenyPublicAccess",
      "Effect": "Deny",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::scanalyze-${account_id}-frontend",
        "arn:aws:s3:::scanalyze-${account_id}-frontend/*"
      ],
      "Principal": "*",
      "Condition": {
        "StringNotEquals": {
          "s3:ResourceAccount": "${account_id}"
        }
      }
    }
  ]
}
